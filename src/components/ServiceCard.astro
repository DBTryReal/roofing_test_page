---
// src/components/ServiceCard.astro
import type { CollectionEntry } from "astro:content";

interface Props {
    service: CollectionEntry<"services">;
}

const { service } = Astro.props;
---

<article class="service-teaser-card">
    <div class="service-media-icon">
        {service.data.icon}
    </div>
    <div class="service-body">
        <h3>{service.data.title}</h3>
        <p>{service.data.tagline}</p>
        <div class="card-footer">
            <span class="service-badge-tag">Garantizado</span>
            <a
                href={`${import.meta.env.BASE_URL}services/${service.id}`}
                class="text-link"
                aria-label={`Saber más sobre ${service.data.title}`}
            >
                Saber más →
            </a>
        </div>
    </div>
</article>

<style>
    .service-teaser-card {
        background-color: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

    .service-teaser-card:hover {
        transform: translateY(-5px);
        box-shadow:
            0 20px 25px -5px rgba(0, 0, 0, 0.08),
            0 10px 10px -5px rgba(0, 0, 0, 0.04);
        border-color: rgba(57, 92, 160, 0.3);
    }

    .service-media-icon {
        font-size: 2.5rem;
        margin-bottom: 20px;
    }

    .service-body h3 {
        font-size: 1.25rem;
        color: #0f172a;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .service-body p {
        font-size: 0.95rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: 24px;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #f1f5f9;
        padding-top: 16px;
        margin-top: auto;
    }

    .service-badge-tag {
        background-color: #f0fdf4;
        color: #16a34a;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 4px;
    }

    .text-link {
        color: #395ca0;
        font-weight: 600;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }

    .text-link:hover {
        color: #293a8b;
    }

    /* ---- SOPORTE MODO OSCURO ---- */
    @media (prefers-color-scheme: dark) {
        .service-teaser-card {
            background-color: #1e293b;
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
        }

        .service-teaser-card:hover {
            border-color: rgba(96, 165, 250, 0.3);
            box-shadow:
                0 20px 25px -5px rgba(0, 0, 0, 0.4),
                0 10px 10px -5px rgba(0, 0, 0, 0.2);
        }

        .service-body h3 {
            color: #f1f5f9;
        }

        .service-body p {
            color: #94a3b8;
        }

        .card-footer {
            border-top-color: rgba(255, 255, 255, 0.08);
        }

        .service-badge-tag {
            background-color: rgba(74, 222, 128, 0.1);
            color: #4ade80;
        }

        .text-link {
            color: #60a5fa;
        }

        .text-link:hover {
            color: #93c5fd;
        }
    }
</style>
