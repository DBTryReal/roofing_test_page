// Recibe opcionalmente un título y descripción para el <head>
interface Props {
    title?: string;
    description?: string;
}
const {
    title = "My website",
    description = "Sitio web sobre Roofing y construcción en Carolina del Norte",
} = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link
            rel="icon"
            type="image/svg+xml"
            href={`${import.meta.env.BASE_URL}favicon.svg`}
        />
        <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>Carolina Prime Construction - {title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href={`${import.meta.env.BASE_URL}/styles/global.css`}
        />
    </head>

    <body>
        <header class="site-header">
            <div class="container">
                <!-- <a href="/" class="site-logo">MiSitio</a> -->
                <!-- <a
                    href="/"
                    class="logo-link"
                    aria-label="Carolina Prime Construction - Ir al inicio"
                > -->
