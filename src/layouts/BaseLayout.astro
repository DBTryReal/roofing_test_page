                    src="/favicon.svg"
                    alt="Carolina Prime Construction Logo"
                    width="100"
                    height="100"
                    loading="eager"
                    decoding="async"
                    aria-hidden="false"
                /> -->

                <!-- Imagen para Modo Claro -->
                <!-- <Image
                        src={logoLight}
                        alt="Carolina Prime Construction Logo"
                        width={160}
                        height={160}
                        loading="eager"
                        decoding="async"
                        class="logo-theme-light"
                    /> -->
                <!-- Imagen para Modo Oscuro -->
                <!-- <Image
                        src={logoDark}
                        alt="Carolina Prime Construction Logo"
                        width={160}
                        height={160}
                        loading="eager"
                        decoding="async"
                        class="logo-theme-dark"
                    /> -->
                <!-- </a> -->

                <nav class="site-nav">
                    <a href={`${import.meta.env.BASE_URL}`}>Home</a>
                    <a href={`${import.meta.env.BASE_URL}index2`}>Home2</a>
                    <a href={`${import.meta.env.BASE_URL}index3`}>Home3</a>
                    <a href={`${import.meta.env.BASE_URL}index4`}>Home4</a>
                    <a href={`${import.meta.env.BASE_URL}services`}>Services</a>
                    <a href={`${import.meta.env.BASE_URL}gallery`}>Gallery</a>
                    <!-- <a href={`${import.meta.env.BASE_URL}kci-steps`}>KCI Steps</a> -->
                    <!-- <a href={`${import.meta.env.BASE_URL}buildings-trailers`}>Buildings & Trailers</a> -->
                    <a href={`${import.meta.env.BASE_URL}about`}>About</a>
                    <a href={`${import.meta.env.BASE_URL}contact`}>Contact</a>
                    <!-- <ul>
                        <li><a href={`${import.meta.env.BASE_URL}`}>Home</a></li>
                        <li><a href={`${import.meta.env.BASE_URL}services`}>Services</a></li>
                        <li><a href={`${import.meta.env.BASE_URL}gallery`}>Gallery</a></li>
                        <li><a href={`${import.meta.env.BASE_URL}kci-steps`}>KCI Steps</a></li>
                        <li>
                            <a href={`${import.meta.env.BASE_URL}buildings-trailers`}
                                >Buildings & Trailers</a
                            >
                        </li>
                        <li><a href={`${import.meta.env.BASE_URL}about`}>About</a></li>
                        <li><a href={`${import.meta.env.BASE_URL}contact`}>Contact</a></li>
                    </ul> -->
                </nav>
            </div>
        </header>
    </body>
    <main class="site-main">
        <!-- Aquí se inyecta el contenido de cada página -->
        <slot />
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>
                &copy; {new Date().getFullYear()} Carolina Prime Construction. All
                rights reserved.
            </p>
        </div>
    </footer>
</html>

