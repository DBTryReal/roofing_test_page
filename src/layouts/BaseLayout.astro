---
import { Image } from "astro:assets";
// for light mode
import logoLight from "../assets/logo-light.webp";
// import logoLightBackground from "../assets/logo-light-background.webp";
// for dark mode
import logoDark from "../assets/logo-dark.webp";
// import logoDarkBackground from "../assets/logo-dark-background.webp";

// Recibe opcionalmente un título y descripción para el <head>
interface Props {
    title?: string;
    description?: string;
}
const {
    title = "Mi Sitio Web",
    description = "Sitio web sobre Roofing y construcción en Carolina del Norte",
} = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>Carolina Prime Construction - {title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
            rel="stylesheet"
        />
        <!-- <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        /> -->
    </head>
    <body>
        <header>
            <a
                href="/"
                class="logo-link"
                aria-label="Carolina Prime Construction - Ir al inicio"
            >
                <!-- <img
                    src="/favicon.svg"
                    alt="Carolina Prime Construction Logo"
                    width="100"
                    height="100"
                    loading="eager"
                    decoding="async"
                    aria-hidden="false"
                /> -->

                <!-- Imagen para Modo Claro -->
                <!-- src={logoLightBackground} -->
                <Image
                    src={logoLight}
                    alt="Carolina Prime Construction Logo"
                    width={160}
                    height={160}
                    loading="eager"
                    decoding="async"
                    class="logo-theme-light"
                />
                <!-- Imagen para Modo Oscuro -->
                <!-- src={logoDarkBackground} -->
                <Image
                    src={logoDark}
                    alt="Carolina Prime Construction Logo"
                    width={160}
                    height={160}
                    loading="eager"
                    decoding="async"
                    class="logo-theme-dark"
                />
            </a>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/gallery">Gallery</a></li>
                    <!-- <li><a href="/kci-steps">KCI Steps</a></li>                     -->
                    <!-- <li>
                        <a href="/buildings-trailers">Buildings & Trailers</a>
                    </li> -->
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </nav>
        </header>
        <main>
            <slot />
        </main>

        <footer>
            <!-- <a
                href="/"
                class="logo-link"
                aria-label="Carolina Prime Construction - Ir al inicio"
            >                
                <Image
                    src={logoLight}
                    alt="Carolina Prime Construction Logo"
                    width={300}
                    height={300}
                    loading="eager"
                    decoding="async"
                    class="logo-theme-light"
                />                
                <Image
                    src={logoDark}
                    alt="Carolina Prime Construction Logo"
                    width={300}
                    height={300}
                    loading="eager"
                    decoding="async"
                    class="logo-theme-dark"
                />
            </a> -->
            <p>
                &copy; {new Date().getFullYear()} Carolina Prime Construction. All
                rights reserved.
            </p>
        </footer>
    </body>
</html>

<style>
    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh; /* Ocupa el 100% del alto de la ventana */
        margin: 0; /* Elimina márgenes por defecto */
    }

    header {
        background-color: #f9f6fc;
        padding: 0px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;

        /* Estilos para el contenedor del logo y texto */
        .logo-link {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            border-bottom: none; /* Quitamos la línea punteada heredada */
        }

        h1 {
            margin: 0;
        }

        ul {
            display: flex;
            list-style: none;
            gap: 16px;
        }

        a {
            text-decoration: none;
            border-bottom: 1px dashed;
        }
    }

    main {
        flex: 1; /* Hace que el main ocupe el espacio restante */
    }

    /* Por defecto, mostramos la versión clara y ocultamos la oscura */
    .logo-theme-dark {
        display: none !important;
    }
    .logo-theme-light {
        display: block !important;
    }

    /* Cuando el sistema del visitante está en modo oscuro (o si cambias el header a negro) */
    @media (prefers-color-scheme: dark) {
        .logo-theme-light {
            display: none !important;
        }
        .logo-theme-dark {
            display: block !important;
        }

        /* Opcional: Ajusta el color del menú para que contraste en fondo oscuro */
        header {
            /* Fondo gris oscuro/negro */
            background-color: #2e2e2e !important;
        }

        header nav a {
            /* Texto de enlaces en blanco */
            color: #fff !important;
        }
    }

    footer {
        background-color: #f9f6fc;
        padding: 10px 20px;
        text-align: center;
        vertical-align: middle;
        width: 100%;
        position: relative;
    }
</style>

<style is:global>
    * {
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
        color: #333;
    }

    .content {
        width: 100%;
        max-width: 1200px;
        margin: 60px auto;
        padding: 0 20px;
        box-sizing: border-box;

        h2 {
            font-size: 1.8rem;
        }

        p {
            font-size: 1.2rem;
        }
    }
</style>
