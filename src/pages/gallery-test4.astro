---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

// Imports directos obligatorios en build-time para optimización de imagen
import p1 from "../assets/images/gallery/proyecto-1.webp";
import p2 from "../assets/images/gallery/proyecto-2.webp";
import p3 from "../assets/images/gallery/proyecto-3.webp";
import p4 from "../assets/images/gallery/proyecto-4.webp";
import p5 from "../assets/images/gallery/proyecto-5.webp";
import p6 from "../assets/images/gallery/proyecto-6.webp";
import p7 from "../assets/images/gallery/proyecto-7.webp";

// Array de datos centralizado
const projects = [
  {
    id: "p1",
    src: p1,
    alt: "Techo residencial reparado con tejas nuevas de asfalto en Charlotte, NC",
    title: "Reparación Residencial",
    location: "Charlotte, NC",
    category: "reparacion",
  },
  {
    id: "p2",
    src: p2,
    alt: "Instalación de techo nuevo con acabado de diseño moderno en Raleigh, NC",
    title: "Instalación Nueva",
    location: "Raleigh, NC",
    category: "instalacion",
  },
  {
    id: "p3",
    src: p3,
    alt: "Mantenimiento preventivo integral de techo comercial en Durham, NC",
    title: "Mantenimiento Preventivo",
    location: "Durham, NC",
    category: "mantenimiento",
  },
  {
    id: "p4",
    src: p4,
    alt: "Reparación de urgencia tras tormenta de granizo en Cary, NC",
    title: "Reparación Urgente",
    location: "Cary, NC",
    category: "reparacion",
  },
  {
    id: "p5",
    src: p5,
    alt: "Instalación de tejas de asfalto de alta durabilidad en Greensboro, NC",
    title: "Tejas de Asfalto",
    location: "Greensboro, NC",
    category: "instalacion",
  },
  {
    id: "p6",
    src: p6,
    alt: "Inspección exhaustiva y sellado de filtraciones en Apex, NC",
    title: "Reparación de Filtraciones",
    location: "Apex, NC",
    category: "mantenimiento",
  },
  {
    id: "p7",
    src: p7,
    alt: "Mantenimiento del sellado y limpieza de canaletas en Raleigh, NC",
    title: "Mantenimiento de Tejado",
    location: "Raleigh, NC",
    category: "mantenimiento",
  },
];

// Extracción dinámica de categorías
const categories = [...new Set(projects.map((p) => p.category))];
---

<BaseLayout
  title="Galería de Proyectos de Roofing"
  description="Exhibición de proyectos de instalación, reparación y mantenimiento de tejados por profesionales capacitados en Carolina del Norte."
>
  <header class="gallery-header container">
    <h1>Nuestros Proyectos Completados</h1>
    <p>
      Echa un vistazo a la calidad de nuestra mano de obra. Filtrar por
      categoría para examinar proyectos de interés.
    </p>
  </header>

  <!-- Filtros Accesibles -->
  <nav class="gallery-filters container" aria-label="Filtrado de proyectos">
    <button class="filter-btn active" data-filter="all" aria-pressed="true">
      Todos ({projects.length})
    </button>
    {
      categories.map((cat) => (
        <button class="filter-btn" data-filter={cat} aria-pressed="false">
          {cat.charAt(0).toUpperCase() + cat.slice(1)} (
          {projects.filter((p) => p.category === cat).length})
        </button>
      ))
    }
  </nav>

  <!-- Galería en base a lista semántica (UL) -->
  <main class="container">
    <ul class="gallery-grid" id="gallery-grid">
      {
        projects.map((project, index) => (
          <li class="gallery-item" data-category={project.category}>
            <figure>
              <button
                class="gallery-trigger"
                aria-label={`Ampliar imagen: ${project.title} en ${project.location}`}
                data-index={index}
              >
                <Image
                  src={project.src}
                  alt={project.alt}
                  width={600}
                  height={450}
                  loading={index < 3 ? "eager" : "lazy"}
                  decoding="async"
                  class="gallery-img"
                />
                <span class="gallery-overlay" aria-hidden="true">
                  <span class="overlay-title">{project.title}</span>
                  <span class="overlay-location">{project.location}</span>
                </span>
              </button>
              <figcaption class="gallery-caption">
                <strong>{project.title}</strong>
                <span>{project.location}</span>
              </figcaption>
            </figure>
          </li>
        ))
      }
    </ul>

    <!-- Estado Vacío -->
    <div class="gallery-empty" id="gallery-empty" aria-live="polite" hidden>
      <p>
        No se encontraron proyectos correspondientes a este filtro en este
        momento.
      </p>
    </div>
  </main>

  <!-- Lightbox Accesible con Dialog -->
  <dialog
    class="lightbox"
    id="lightbox"
    aria-modal="true"
    aria-label="Visor ampliado de imágenes"
  >
    <div class="lightbox-container">
      <button
        class="lightbox-close"
        id="lightbox-close"
        aria-label="Cerrar visor">✕</button
      >

      <button
        class="lightbox-nav lightbox-prev"
        id="lightbox-prev"
        aria-label="Imagen anterior">‹</button
      >

      <figure class="lightbox-figure">
        <img
          id="lightbox-img"
          src=""
          alt=""
          width="1200"
          height="900"
          decoding="async"
        />
        <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
      </figure>

      <button
        class="lightbox-nav lightbox-next"
        id="lightbox-next"
        aria-label="Imagen siguiente">›</button
      >
    </div>
  </dialog>
</BaseLayout>

<style>
  /* ──── ESTILOS DE LA GALERÍA (OPCIÓN A: Grid Uniforme) ──── */
  .gallery-header {
    text-align: center;
    padding: 60px 0 30px;
  }
  .gallery-header h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .gallery-header p {
    font-size: 1.125rem;
    color: #4a5568;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .gallery-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: 40px;
  }
  .filter-btn {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: #4a5568;
    background: #edf2f7;
    border: 2px solid transparent;
    padding: 10px 22px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .filter-btn:hover {
    background: #e2e8f0;
    color: #2d3748;
  }
  .filter-btn.active,
  .filter-btn[aria-pressed="true"] {
    background: #1a365d;
    color: #ffffff;
  }
  .filter-btn:focus-visible {
    outline: 3px solid #3182ce;
    outline-offset: 2px;
  }

  /* OPCIONES DE VISUALIZACIÓN EN CSS (Configurables) */

  /* [Opción 1: Grid Uniforme - Predeterminado por su gran consistencia en UI] */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    padding: 0;
    margin: 0 0 60px;
    list-style: none;
  }

  /* [Opción 2: Layout Masonry Dinámico (Descomentar para usar)] */
  /*
  .gallery-grid {
    columns: 3 300px;
    column-gap: 30px;
    padding: 0;
    margin: 0 0 60px;
    list-style: none;
  }
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 30px;
    display: inline-block;
    width: 100%;
  }
  */

  .gallery-item {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-item:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
  }
  .gallery-item[hidden] {
    display: none !important;
  }

  .gallery-item figure {
    margin: 0;
  }

  .gallery-trigger {
    position: relative;
    width: 100%;
    border: none;
    background: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    display: block;
    overflow: hidden;
  }
  .gallery-trigger:focus-visible {
    outline: 3px solid #3182ce;
    outline-offset: -3px;
  }

  .gallery-img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-trigger:hover .gallery-img,
  .gallery-trigger:focus-visible .gallery-img {
    transform: scale(1.08);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 54, 93, 0) 40%,
      rgba(26, 54, 93, 0.9) 100%
    );
    opacity: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 24px;
    text-align: left;
    transition: opacity 0.3s ease;
  }
  .gallery-trigger:hover .gallery-overlay,
  .gallery-trigger:focus-visible .gallery-overlay {
    opacity: 1;
  }
  .overlay-title {
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .overlay-location {
    color: #e2e8f0;
    font-size: 0.85rem;
    margin-top: 4px;
  }

  .gallery-caption {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gallery-caption strong {
    color: #2d3748;
    font-size: 1.05rem;
  }
  .gallery-caption span {
    color: #718096;
    font-size: 0.85rem;
  }

  .gallery-empty {
    text-align: center;
    padding: 80px 20px;
    background: #edf2f7;
    border-radius: 12px;
    color: #4a5568;
    font-weight: 500;
    margin-bottom: 60px;
  }

  /* ──── DIALOG / LIGHTBOX CSS ──── */
  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: fixed;
    inset: 0;
  }
  .lightbox::backdrop {
    background: rgba(10, 17, 40, 0.95);
    backdrop-filter: blur(8px);
  }
  .lightbox-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-sizing: border-box;
  }

  .lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    max-width: 90vw;
    max-height: 90vh;
  }
  #lightbox-img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    background: rgba(0, 0, 0, 0.2);
  }
  .lightbox-caption {
    color: #cbd5e0;
    margin-top: 20px;
    font-size: 1rem;
    text-align: center;
    font-weight: 500;
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-size: 2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s,
      opacity 0.2s;
    z-index: 10;
  }
  .lightbox-prev {
    left: 24px;
  }
  .lightbox-next {
    right: 24px;
  }
  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .lightbox-nav:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  .lightbox-close:focus-visible,
  .lightbox-nav:focus-visible {
    outline: 3px solid #3182ce;
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }
    .lightbox-nav {
      display: none; /* En dispositivos móviles se prefiere la navegación táctil por deslizamiento */
    }
    .lightbox-figure {
      padding: 20px;
    }
    #lightbox-img {
      max-height: 65vh;
    }
  }
</style>

<script>
  // ── SCRIPT DE FILTRADO Y MANEJO DEL LIGHTBOX ──
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const gridItems = document.querySelectorAll<HTMLElement>(".gallery-item");
  const emptyMessage = document.getElementById("gallery-empty")!;

  // Lógica del filtro
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selectedFilter = btn.dataset.filter!;

      // Modificar clases de botones activos
      filterBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");

      let matches = 0;
      gridItems.forEach((item) => {
        const itemCategory = item.dataset.category!;
        const isSelected =
          selectedFilter === "all" || itemCategory === selectedFilter;
        item.hidden = !isSelected;
        if (isSelected) matches++;
      });

      emptyMessage.hidden = matches > 0;
    });
  });

  // Lógica del Lightbox
  const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lbCaption = document.getElementById("lightbox-caption")!;
  const lbClose = document.getElementById("lightbox-close")!;
  const lbPrev = document.getElementById("lightbox-prev") as HTMLButtonElement;
  const lbNext = document.getElementById("lightbox-next") as HTMLButtonElement;

  let currentIndex = 0;

  function getVisibleTriggers(): HTMLButtonElement[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>(".gallery-trigger"),
    ).filter((trigger) => {
      const item = trigger.closest(".gallery-item") as HTMLElement;
      return item && !item.hidden;
    });
  }

  function renderImage(index: number) {
    const triggers = getVisibleTriggers();
    if (index < 0 || index >= triggers.length) return;
    currentIndex = index;

    const currentTrigger = triggers[index];
    const imageInside = currentTrigger.querySelector("img")!;
    const itemEl = currentTrigger.closest(".gallery-item")!;
    const captionSpan = itemEl.querySelector(".gallery-caption")!;

    lbImg.src = imageInside.src;
    lbImg.alt = imageInside.alt;
    lbCaption.textContent =
      captionSpan.textContent?.replace(/\s+/g, " ").trim() ?? "";

    lbPrev.disabled = currentIndex === 0;
    lbNext.disabled = currentIndex === triggers.length - 1;

    // Manejar el foco internamente si un botón pasa a ser deshabilitado
    if (lbPrev.disabled && document.activeElement === lbPrev) {
      lbNext.focus();
    } else if (lbNext.disabled && document.activeElement === lbNext) {
      lbPrev.focus();
    }
  }

  function openLightbox(index: number) {
    renderImage(index);
    document.body.style.overflow = "hidden"; // Desactivar scrolling del fondo
    lightbox.showModal();
  }

  function closeLightbox() {
    lightbox.close();
    document.body.style.overflow = ""; // Reactivar scrolling
    // Devolver foco al trigger original
    const triggers = getVisibleTriggers();
    if (triggers[currentIndex]) {
      triggers[currentIndex].focus();
    }
  }

  // Event Listeners
  document
    .querySelectorAll<HTMLButtonElement>(".gallery-trigger")
    .forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const triggers = getVisibleTriggers();
        const realIndex = triggers.indexOf(trigger);
        if (realIndex !== -1) {
          openLightbox(realIndex);
        }
      });
    });

  lbClose.addEventListener("click", closeLightbox);
  lightbox.addEventListener("close", closeLightbox);

  lbPrev.addEventListener("click", () => {
    if (currentIndex > 0) renderImage(currentIndex - 1);
  });

  lbNext.addEventListener("click", () => {
    const triggers = getVisibleTriggers();
    if (currentIndex < triggers.length - 1) renderImage(currentIndex + 1);
  });

  // Clic fuera del contenido cierra el diálogo
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Manejo de teclado
  lightbox.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft" && !lbPrev.disabled) {
      lbPrev.click();
    } else if (e.key === "ArrowRight" && !lbNext.disabled) {
      lbNext.click();
    }
  });

  // Navegación mediante desplazamiento móvil (Swipe gestures)
  let touchStartX = 0;
  lightbox.addEventListener(
    "touchstart",
    (e) => {
      touchStartX = e.touches[0].clientX;
    },
    { passive: true },
  );

  lightbox.addEventListener(
    "touchend",
    (e) => {
      const touchEndX = e.changedTouches[0].clientX;
      const diff = touchEndX - touchStartX;

      if (Math.abs(diff) > 60) {
        if (diff < 0 && !lbNext.disabled) {
          lbNext.click(); // Deslizar izquierda -> siguiente
        } else if (diff > 0 && !lbPrev.disabled) {
          lbPrev.click(); // Deslizar derecha -> anterior
        }
      }
    },
    { passive: true },
  );
</script>
