---
// // way 1: one file
// import { Content, frontmatter } from "../content/about.md";
// import BaseLayout from "../layouts/BaseLayout.astro";

//
// CONCEPTO CLAVE:
// getEntry("pages", "about") carga UN SOLO archivo de la colección.
// El primer argumento es el nombre de la colección.
// El segundo argumento es el ID del archivo (nombre sin extensión).
// "about" corresponde a src/content/about.md
//
// render(about) convierte el markdown en un componente <Content />
// que luego usamos en el template como si fuera cualquier componente Astro.

// way 2: multiple files or one if not mare than 1
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Carga específicamente el archivo "about.md" de la colección "pages"
const about = await getEntry("pages", "about");
if (!about) {
    throw new Error(
        'No se encontró la entrada "about" en la colección "pages".',
    );
}
// Convierte el markdown en un componente HTML
const { Content } = await render(about);
---

<BaseLayout title={`${about.data.title}`} description={about.data.description}>
    <!-- way 1 -->
    <!-- <h1>{frontmatter.title}</h1>
    <p class="description">{frontmatter.description}</p> -->

    <!-- ============================================================
         CABECERA DE PÁGINA
         ============================================================ -->
    <section class="page-hero">
        <div class="container">
            <span class="sec-subtitle">Nuestra Empresa</span>
            <h1>{about.data.title}</h1>
            <p class="page-desc">{about.data.description}</p>
            {
                about.data.founding_year && (
                    <div class="about-meta">
                        <span class="meta-item">
                            📅 Fundados en {about.data.founding_year}
                        </span>
                        {about.data.team_size && (
                            <span class="meta-item">
                                👥 {about.data.team_size}+ profesionales
                            </span>
                        )}
                        {about.data.location && (
                            <span class="meta-item">
                                📍 {about.data.location}
                            </span>
                        )}
                    </div>
                )
            }
        </div>
    </section>

    <!-- ============================================================
         CONTENIDO MARKDOWN
         ============================================================ -->
    <section class="about-body">
        <div class="container">
            <div class="prose">
                <Content />
            </div>
        </div>
    </section>

    <!-- ============================================================
         CTA BANNER FINAL
         ============================================================ -->
    <section class="cta-banner container">
        <div class="cta-banner-box">
            <div class="cta-text-cnt">
                <h2>¿Listo para proteger tu hogar o negocio?</h2>
                <p>
                    Solicita una inspección gratuita sin compromiso. Te
                    respondemos en menos de 24 horas.
                </p>
            </div>
            <div class="cta-action-cnt">
                <a href="/contact" class="btn-white-accent">
                    Agendar Mi Inspección Gratis
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* ============================================================
       CABECERA DE PÁGINA
       ============================================================ */
    .page-hero {
        background-color: #0f172a;
        color: #fff;
        padding: 80px 24px;
    }

    .sec-subtitle {
        color: #395ca0;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        display: block;
        margin-bottom: 12px;
    }

    .page-hero h1 {
        font-size: 2.75rem;
        font-weight: 700;
        line-height: 1.15;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

    .page-desc {
        font-size: 1.15rem;
        color: #cbd5e1;
        line-height: 1.6;
        max-width: 650px;
        margin-bottom: 20px;
    }

    .about-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .meta-item {
        background-color: rgba(255, 255, 255, 0.08);
        color: #e2e8f0;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    /* ============================================================
       CUERPO DE CONTENIDO
       ============================================================ */
    .about-body {
        padding: 72px 24px;
    }

    /* ============================================================
       CTA BANNER FINAL (igual que index2)
       ============================================================ */
    .cta-banner {
        padding: 80px 24px;
    }

    .cta-banner-box {
        background-color: #395ca0;
        border-radius: 16px;
        padding: 48px 60px;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 40px;
        box-shadow: 0 20px 45px rgba(57, 92, 160, 0.25);
    }

    .cta-text-cnt {
        max-width: 600px;
    }

    .cta-banner-box h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 12px;
        line-height: 1.2;
    }

    .cta-banner-box p {
        font-size: 1.1rem;
        color: #e2e8f0;
        line-height: 1.5;
        margin: 0;
    }

    .btn-white-accent {
        background-color: #fff;
        color: #395ca0;
        padding: 16px 32px;
        font-weight: 700;
        font-size: 1.05rem;
        border-radius: 6px;
        display: inline-block;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        transition: all 0.25s ease;
    }

    .btn-white-accent:hover {
        background-color: #f1f5f9;
        color: #293a8b;
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .page-hero h1 {
            font-size: 1.9rem;
        }

        .cta-banner-box {
            flex-direction: column;
            text-align: center;
            padding: 36px 28px;
        }
    }
</style>
