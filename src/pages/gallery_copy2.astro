---
// ── 1. IMPORTS ────────────────────────────────────────────────────────
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

// Importar cada imagen individualmente.
// Astro las procesa en build time: comprime, convierte a WebP, genera srcset.
import p1 from "../assets/images/gallery/proyecto-1.webp";
import p2 from "../assets/images/gallery/proyecto-2.webp";
import p3 from "../assets/images/gallery/proyecto-3.webp";
import p4 from "../assets/images/gallery/proyecto-4.webp";
import p5 from "../assets/images/gallery/proyecto-5.webp";
import p6 from "../assets/images/gallery/proyecto-6.webp";
import p7 from "../assets/images/gallery/proyecto-7.webp";

// ── 2. DATOS DE LA GALERÍA ────────────────────────────────────────────
// Un array de objetos con la metadata de cada proyecto.
// Esto vive en el frontmatter (código JavaScript del servidor, nunca llega al browser).
// Si el array crece mucho, puede moverse a src/data/gallery.ts
const projects = [
    {
        src: p1,
        alt: "Techo residencial de tejas nuevas instalado en Charlotte, NC",
        title: "Instalación residencial completa",
        location: "Charlotte, NC",
        category: "instalacion",
    },
    {
        src: p2,
        alt: "Reparación de techo con daños por granizo en Raleigh, NC",
        title: "Reparación por granizo",
        location: "Raleigh, NC",
        category: "reparacion",
    },
    {
        src: p3,
        alt: "Techo comercial con membrana TPO instalada en Durham, NC",
        title: "Techo comercial TPO",
        location: "Durham, NC",
        category: "comercial",
    },
    {
        src: p4,
        alt: "Mantenimiento preventivo de canaletas en Greensboro, NC",
        title: "Mantenimiento de canaletas",
        location: "Greensboro, NC",
        category: "mantenimiento",
    },
    {
        src: p5,
        alt: "Instalación de paneles solares sobre techo reforzado en Chapel Hill",
        title: "Techo con paneles solares",
        location: "Chapel Hill, NC",
        category: "instalacion",
    },
    {
        src: p6,
        alt: "Reparación de filtraciones en techo plano residencial en Cary, NC",
        title: "Reparación de filtraciones",
        location: "Cary, NC",
        category: "reparacion",
    },
    {
        src: p7,
        alt: "Mantenimiento de techo en Raleigh, NC",
        title: "Mantenimiento de techo",
        location: "Raleigh, NC",
        category: "mantenimiento",
    },
] as const;

// ── 3. LISTA DE CATEGORÍAS únicas para los botones de filtro ──────────
// Se genera dinámicamente del array anterior para no repetir a mano.
// Set elimina duplicados, Array.from lo convierte a array iterable.
const categories = ["todos", ...new Set(projects.map((p) => p.category))];
---

<!-- ── 4. LAYOUT ──────────────────────────────────────────────────────── --><!-- BaseLayout inyecta el <head> con meta description para SEO -->
<BaseLayout
    title="Galería de proyectos"
    description="Explora nuestros proyectos de instalación, reparación y mantenimiento de techos en Carolina del Norte."
>
    <main class="page-content">
        <!-- ── 5. INTRO ──────────────────────────────────────────────────── -->
        <!-- h1 (no h2) porque esta sección ES el título principal de la página -->
        <section class="gallery-intro">
            <h1>Proyectos recientes</h1>
            <p>
                Explora algunos de nuestros trabajos en instalación, reparación,
                comercial y mantenimiento de techos en Carolina del Norte.
            </p>
        </section>

        <!-- ── 6. FILTROS ────────────────────────────────────────────────── -->
        <!-- role="group" + aria-label agrupa los botones semánticamente -->
        <!-- data-filter es el atributo que lee el JS para filtrar -->
        <div
            class="gallery-filters"
            role="group"
            aria-label="Filtrar proyectos por categoría"
        >
            {
                categories.map((cat) => (
                    <button
                        class:list={["filter-btn", { active: cat === "todos" }]}
                        data-filter={cat}
                        aria-pressed={cat === "todos" ? "true" : "false"}
                    >
                        {/* Capitaliza la primera letra para el label visible */}
                        {cat.charAt(0).toUpperCase() + cat.slice(1)}
                    </button>
                ))
            }
        </div>

        <!-- ── 7. GRID DE GALERÍA ─────────────────────────────────────────── -->
        <!-- ul + li porque semánticamente es una lista de items -->
        <!-- data-category en cada li es leído por el JS del filtro -->
        <ul class="gallery-grid" role="list">
            {
                projects.map((project, index) => (
                    <li class="gallery-item" data-category={project.category}>
                        {/*
            El <button> hace que el elemento sea tecleable y anunciado
            por lectores de pantalla como "botón interactivo".
            data-index permite al lightbox saber qué imagen mostrar.
          */}
                        <button
                            class="gallery-trigger"
                            type="button"
                            data-index={index}
                            aria-label={`Ver imagen ampliada: ${project.title} - ${project.location}`}
                        >
                            {/*
              <Image> de astro:assets:
              - Genera automáticamente srcset para múltiples resoluciones
              - Convierte a WebP si el browser lo soporta
              - Incluye width y height para prevenir CLS (Cumulative Layout Shift)
              - loading="lazy" aplaza la carga de imágenes fuera del viewport
              - decoding="async" no bloquea el hilo principal
            */}
                            <Image
                                src={project.src}
                                alt={project.alt}
                                width={800}
                                height={600}
                                loading="lazy"
                                decoding="async"
                                class="gallery-img"
                            />
                            {/*
              El overlay aparece en hover via CSS.
              aria-hidden="true" porque el texto ya está en aria-label del button.
            */}
                            <div class="gallery-overlay" aria-hidden="true">
                                <strong class="overlay-title">
                                    {project.title}
                                </strong>
                                <span class="overlay-location">
                                    {project.location}
                                </span>
                            </div>
                        </button>
                    </li>
                ))
            }
        </ul>

        <!-- ── 8. LIGHTBOX (elemento <dialog> nativo HTML5) ──────────────── -->
        <!--
      <dialog> es el elemento HTML nativo para modales/diálogos.
      Ventajas vs div+overlay:
      - Tiene focus trap automático (teclado no escapa del modal)
      - Backdrop nativo con ::backdrop pseudo-elemento
      - ESC lo cierra automáticamente
      - Anunciado correctamente por lectores de pantalla
      - No requiere z-index manual
    -->
        <dialog
            class="lightbox"
            id="lightbox"
            aria-label="Visor de imagen ampliada"
        >
            <!-- Botón cerrar: aria-label describe la acción, × es solo visual -->
            <button
                class="lightbox-close"
                type="button"
                aria-label="Cerrar visor"
            >
                <span aria-hidden="true">×</span>
            </button>

            <!-- Navegación anterior -->
            <button
                class="lightbox-nav lightbox-prev"
                type="button"
                aria-label="Imagen anterior"
            >
                <span aria-hidden="true">‹</span>
            </button>

            <!-- Contenedor de imagen + caption -->
            <figure class="lightbox-figure">
                <!-- src y alt se rellenan dinámicamente desde el JS -->
                <img
                    class="lightbox-img"
                    src=""
                    alt=""
                    width="1200"
                    height="900"
                />
                <figcaption class="lightbox-caption"></figcaption>
            </figure>

            <!-- Navegación siguiente -->
            <button
                class="lightbox-nav lightbox-next"
                type="button"
                aria-label="Siguiente imagen"
            >
                <span aria-hidden="true">›</span>
            </button>
        </dialog>
    </main>
</BaseLayout>

<!-- ── 9. ESTILOS (scoped: solo aplican a este componente) ───────────── -->
<style>
    /* ── INTRO ─────────────────────────────────────────────── */
    .gallery-intro {
        text-align: center;
        padding: 48px 0 32px;
    }

    .gallery-intro h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 12px;
    }

    .gallery-intro p {
        font-size: 1.05rem;
        color: #666;
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* ── FILTROS ───────────────────────────────────────────── */
    .gallery-filters {
        display: flex;
        flex-wrap: wrap; /* En mobile se apilan */
        gap: 10px;
        justify-content: center;
        margin-bottom: 36px;
    }

    .filter-btn {
        padding: 8px 20px;
        border: 2px solid #395ca0;
        border-radius: 999px; /* Forma pill */
        background: transparent;
        color: #395ca0;
        font-family: inherit;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition:
            background 0.2s,
            color 0.2s;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: #395ca0;
        color: #fff;
    }

    /* ── GRID ──────────────────────────────────────────────── */
    /*
    CSS Grid con auto-fill + minmax:
    - auto-fill: crea tantas columnas como quepan
    - minmax(280px, 1fr): mínimo 280px, máximo 1 fracción del espacio
    - Resultado: 1 col en mobile, 2 en tablet, 3 en desktop — sin media queries
  */
    .gallery-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        padding: 0;
        margin: 0;
    }

    /* ── ITEM ───────────────────────────────────────────────── */
    .gallery-item {
        /* Oculta items filtrados sin reflow del grid */
        transition:
            opacity 0.3s,
            transform 0.3s;
    }

    /* Clase que aplica el JS al filtrar */
    .gallery-item[aria-hidden="true"] {
        display: none;
    }

    /* ── TRIGGER (botón invisible que envuelve la imagen) ───── */
    .gallery-trigger {
        position: relative;
        display: block;
        width: 100%;
        border: none;
        padding: 0;
        background: none;
        cursor: zoom-in;
        border-radius: 10px;
        overflow: hidden;
        /* Sombra sutil, se intensifica en hover */
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition:
            box-shadow 0.3s,
            transform 0.3s;
    }

    .gallery-trigger:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
        transform: translateY(-3px); /* Efecto de levitación */
    }

    /* Foco visible para teclado (accesibilidad) */
    .gallery-trigger:focus-visible {
        outline: 3px solid #395ca0;
        outline-offset: 3px;
    }

    /* ── IMAGEN ─────────────────────────────────────────────── */
    .gallery-img {
        width: 100%;
        height: 220px;
        object-fit: cover; /* Recorta sin deformar */
        display: block;
        transition: transform 0.4s ease;
    }

    .gallery-trigger:hover .gallery-img {
        transform: scale(1.05); /* Zoom sutil al hover */
    }

    /* ── OVERLAY (texto sobre imagen, visible en hover) ──────── */
    .gallery-overlay {
        position: absolute;
        inset: 0; /* Cubre toda la imagen (top/right/bottom/left: 0) */
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.75) 0%,
            transparent 60%
        );
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 16px;
        color: #fff;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .gallery-trigger:hover .gallery-overlay,
    .gallery-trigger:focus-visible .gallery-overlay {
        opacity: 1;
    }

    .overlay-title {
        font-size: 0.95rem;
        font-weight: 600;
        line-height: 1.3;
    }

    .overlay-location {
        font-size: 0.8rem;
        opacity: 0.85;
        margin-top: 2px;
    }

    /* ── LIGHTBOX ───────────────────────────────────────────── */
    /*
    dialog[open] es el estado cuando .showModal() se llama.
    ::backdrop es el overlay oscuro nativo del <dialog>.
  */
    .lightbox {
        border: none;
        border-radius: 12px;
        padding: 0;
        background: #111;
        max-width: min(90vw, 1100px);
        max-height: 90vh;
        width: 100%;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
    }

    .lightbox::backdrop {
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(4px); /* Desenfoca el fondo */
    }

    /* Centra el dialog en pantalla */
    .lightbox {
        position: fixed;
        inset: 0;
        margin: auto;
    }

    .lightbox-figure {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 0;
    }

    .lightbox-img {
        width: 100%;
        max-height: 80vh;
        object-fit: contain; /* Muestra la imagen completa sin recortar */
        display: block;
    }

    .lightbox-caption {
        color: #ccc;
        font-size: 0.875rem;
        padding: 12px 20px;
        text-align: center;
    }

    .lightbox-close {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(255, 255, 255, 0.15);
        border: none;
        color: #fff;
        font-size: 1.5rem;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        transition: background 0.2s;
    }

    .lightbox-close:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.15);
        border: none;
        color: #fff;
        font-size: 2rem;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .lightbox-nav:hover {
        background: rgba(255, 255, 255, 0.3);
    }
    .lightbox-prev {
        left: 12px;
    }
    .lightbox-next {
        right: 12px;
    }

    /* ── RESPONSIVE ─────────────────────────────────────────── */
    @media (max-width: 600px) {
        .gallery-intro h1 {
            font-size: 1.6rem;
        }
        .gallery-grid {
            grid-template-columns: 1fr;
        } /* 1 columna en mobile */
        .gallery-overlay {
            opacity: 1;
        } /* Siempre visible en touch */
    }
</style>

<!-- ── 10. JAVASCRIPT (vanilla, sin frameworks) ────────────────────── -->
<!--
  is:inline → Astro no procesa ni bundle este script, va directo al HTML.
  Para scripts pequeños y sin imports es la opción más simple.
  Alternativa: omitir is:inline y Astro lo bundlea (mejor para código grande).
-->
<script>
    // ── FILTROS ──────────────────────────────────────────────────────────
    const filterBtns =
        document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const galleryItems =
        document.querySelectorAll<HTMLLIElement>(".gallery-item");

    filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter ?? "todos";

            // Actualiza estado activo y aria-pressed en todos los botones
            filterBtns.forEach((b) => {
                b.classList.toggle("active", b === btn);
                b.setAttribute("aria-pressed", b === btn ? "true" : "false");
            });

            // Muestra u oculta items según categoría
            galleryItems.forEach((item) => {
                const match =
                    filter === "todos" || item.dataset.category === filter;
                // aria-hidden oculta del DOM accesible + el CSS lo quita de la vista
                item.setAttribute("aria-hidden", match ? "false" : "true");
            });
        });
    });

    // ── LIGHTBOX ─────────────────────────────────────────────────────────
    // Recopila los datos de cada imagen para navegar en el lightbox
    const projectsData = Array.from(
        document.querySelectorAll<HTMLButtonElement>(".gallery-trigger"),
    ).map((btn) => {
        const img = btn.querySelector("img")!;
        const title = btn.querySelector(".overlay-title")?.textContent ?? "";
        const loc = btn.querySelector(".overlay-location")?.textContent ?? "";
        return { src: img.src, alt: img.alt, caption: `${title} · ${loc}` };
    });

    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const lightboxImg =
        dialog.querySelector<HTMLImageElement>(".lightbox-img")!;
    const lightboxCaption =
        dialog.querySelector<HTMLElement>(".lightbox-caption")!;
    let currentIndex = 0;

    function showImage(index: number) {
        currentIndex = (index + projectsData.length) % projectsData.length; // wrap around
        const data = projectsData[currentIndex];
        lightboxImg.src = data.src;
        lightboxImg.alt = data.alt;
        lightboxCaption.textContent = data.caption;
    }

    // Abre lightbox al hacer click en cualquier item
    document
        .querySelectorAll<HTMLButtonElement>(".gallery-trigger")
        .forEach((btn) => {
            btn.addEventListener("click", () => {
                const index = parseInt(btn.dataset.index ?? "0", 10);
                showImage(index);
                dialog.showModal(); // API nativa de <dialog>
            });
        });

    // Cierra con el botón ×
    dialog
        .querySelector(".lightbox-close")!
        .addEventListener("click", () => dialog.close());

    // Cierra al hacer click en el backdrop (fuera de la imagen)
    dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
    });

    // Navegación con botones
    dialog
        .querySelector(".lightbox-prev")!
        .addEventListener("click", () => showImage(currentIndex - 1));
    dialog
        .querySelector(".lightbox-next")!
        .addEventListener("click", () => showImage(currentIndex + 1));

    // Navegación con teclado (← → Esc — Esc lo cierra el browser automáticamente)
    dialog.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") showImage(currentIndex - 1);
        if (e.key === "ArrowRight") showImage(currentIndex + 1);
    });
</script>
