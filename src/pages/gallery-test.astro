---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

import p1 from "../assets/images/gallery/proyecto-1.webp";
import p2 from "../assets/images/gallery/proyecto-2.webp";
import p3 from "../assets/images/gallery/proyecto-3.webp";
import p4 from "../assets/images/gallery/proyecto-4.webp";
import p5 from "../assets/images/gallery/proyecto-5.webp";
import p6 from "../assets/images/gallery/proyecto-6.webp";
import p7 from "../assets/images/gallery/proyecto-7.webp";

const projects = [
    {
        src: p1,
        alt: "Techo residencial reparado con tejas nuevas en Charlotte, NC",
        title: "Reparación residencial",
        location: "Charlotte, NC",
        category: "reparacion",
    },
    {
        src: p2,
        alt: "Instalación de techo nuevo con acabado moderno en Raleigh, NC",
        title: "Instalación nueva",
        location: "Raleigh, NC",
        category: "instalacion",
    },
    {
        src: p3,
        alt: "Mantenimiento preventivo de techo en Durham, NC",
        title: "Mantenimiento preventivo",
        location: "Durham, NC",
        category: "mantenimiento",
    },
    {
        src: p4,
        alt: "Reparación de urgencia tras tormenta en Cary, NC",
        title: "Reparación urgente",
        location: "Cary, NC",
        category: "reparacion",
    },
    {
        src: p5,
        alt: "Instalación de tejas de asfalto en Greensboro, NC",
        title: "Tejas de asfalto",
        location: "Greensboro, NC",
        category: "instalacion",
    },
    {
        src: p6,
        alt: "Inspección y sellado de goteras en Apex, NC",
        title: "Reparación de goteras",
        location: "Apex, NC",
        category: "mantenimiento",
    },
    {
        src: p7,
        alt: "Mantenimiento de techo en Raleigh, NC",
        title: "Mantenimiento de techo",
        location: "Raleigh, NC",
        category: "mantenimiento",
    },
];

const categories = [...new Set(projects.map((p) => p.category))];

// SEO estructurado opcional (mejora rich snippets)
const imageObjects = projects.map((p) => ({
    "@type": "ImageObject",
    contentUrl: p.src.src,
    caption: `${p.title} - ${p.location}`,
    description: p.alt,
}));
---

<BaseLayout
    title="Galería de Proyectos"
    description="Proyectos recientes de roofing: instalaciones, reparaciones y mantenimiento en Carolina del Norte."
>
    <section class="gallery-intro container">
        <h1>Proyectos recientes</h1>
        <p>
            Explora trabajos reales de instalación, reparación y mantenimiento
            de techos.
        </p>
    </section>

    <div
        class="gallery-filters container"
        role="group"
        aria-label="Filtrar proyectos"
    >
        <button
            type="button"
            class="filter-btn active"
            data-filter="all"
            aria-pressed="true"
        >
            Todos ({projects.length})
        </button>
        {
            categories.map((cat) => (
                <button
                    type="button"
                    class="filter-btn"
                    data-filter={cat}
                    aria-pressed="false"
                >
                    {cat.charAt(0).toUpperCase() + cat.slice(1)} (
                    {projects.filter((p) => p.category === cat).length})
                </button>
            ))
        }
    </div>

    <div class="gallery-grid container" role="list" id="gallery-grid">
        {
            projects.map((project, index) => (
                <figure
                    class="gallery-item"
                    role="listitem"
                    data-category={project.category}
                >
                    <button
                        type="button"
                        class="gallery-trigger"
                        data-index={index}
                        aria-label={`Ampliar imagen: ${project.title} en ${project.location}`}
                    >
                        <Image
                            src={project.src}
                            alt={project.alt}
                            width={900}
                            height={640}
                            loading={index === 0 ? "eager" : "lazy"}
                            fetchpriority={index === 0 ? "high" : "auto"}
                            decoding="async"
                            class="gallery-img"
                            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        />
                        <div class="gallery-overlay" aria-hidden="true">
                            <strong>{project.title}</strong>
                            <span>{project.location}</span>
                        </div>
                    </button>
                    <figcaption>
                        <strong>{project.title}</strong>
                        <span>{project.location}</span>
                    </figcaption>
                </figure>
            ))
        }
    </div>

    <p
        id="gallery-empty"
        class="gallery-empty container"
        aria-live="polite"
        hidden
    >
        No hay proyectos en esta categoría todavía.
    </p>

    <dialog
        class="lightbox"
        id="lightbox"
        aria-modal="true"
        aria-label="Visor de imágenes"
    >
        <button
            type="button"
            class="lightbox-close"
            id="lightbox-close"
            aria-label="Cerrar visor">✕</button
        >
        <button
            type="button"
            class="lightbox-nav lightbox-prev"
            id="lightbox-prev"
            aria-label="Imagen anterior">‹</button
        >

        <figure class="lightbox-figure">
            <img
                id="lightbox-img"
                src=""
                alt=""
                width="1200"
                height="900"
                decoding="async"
            />
            <figcaption id="lightbox-caption" class="lightbox-caption">
            </figcaption>
        </figure>

        <button
            type="button"
            class="lightbox-nav lightbox-next"
            id="lightbox-next"
            aria-label="Imagen siguiente">›</button
        >
    </dialog>

    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "CollectionPage",
            name: "Galería de Proyectos de Roofing",
            hasPart: imageObjects,
        })}
    />
</BaseLayout>

<style>
    :root {
        --gallery-primary: #184a78;
        --gallery-primary-2: #2b6aa8;
        --gallery-surface: #ffffff;
        --gallery-bg: #f4f7fb;
        --gallery-text: #1b2631;
        --gallery-muted: #5f6d7a;
        --gallery-ring: #0f4c81;
    }

    .gallery-intro {
        text-align: center;
        padding: 44px 0 24px;
    }

    .gallery-intro h1 {
        font-size: clamp(1.6rem, 3.6vw, 2.4rem);
        color: var(--gallery-text);
        margin-bottom: 8px;
    }

    .gallery-intro p {
        color: var(--gallery-muted);
        max-width: 62ch;
        margin: 0 auto;
    }

    .gallery-filters {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        padding-bottom: 28px;
    }

    .filter-btn {
        border: 2px solid transparent;
        border-radius: 999px;
        padding: 8px 16px;
        background: #e8eef6;
        color: #2d4457;
        cursor: pointer;
        transition: 180ms ease;
    }

    .filter-btn:hover {
        border-color: var(--gallery-primary);
        color: var(--gallery-primary);
    }

    .filter-btn.active,
    .filter-btn[aria-pressed="true"] {
        background: var(--gallery-primary);
        color: #fff;
        border-color: var(--gallery-primary);
    }

    .filter-btn:focus-visible {
        outline: 3px solid var(--gallery-ring);
        outline-offset: 2px;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 18px;
        padding-bottom: 56px;
        align-items: start;
    }

    .gallery-item {
        margin: 0;
        background: var(--gallery-surface);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #d7e1ed;
        box-shadow: 0 4px 14px rgba(12, 36, 61, 0.08);
        transition:
            transform 220ms ease,
            box-shadow 220ms ease;
        content-visibility: auto;
        contain-intrinsic-size: 320px;
    }

    .gallery-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 24px rgba(12, 36, 61, 0.16);
    }

    .gallery-item[hidden] {
        display: none;
    }

    .gallery-trigger {
        width: 100%;
        border: 0;
        background: none;
        padding: 0;
        display: block;
        position: relative;
        cursor: pointer;
        overflow: hidden;
    }

    .gallery-trigger:focus-visible {
        outline: 3px solid var(--gallery-ring);
        outline-offset: -3px;
    }

    .gallery-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        transition: transform 260ms ease;
    }

    .gallery-trigger:hover .gallery-img,
    .gallery-trigger:focus-visible .gallery-img {
        transform: scale(1.05);
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: end;
        flex-direction: column;
        padding: 14px;
        color: #fff;
        opacity: 0;
        transition: opacity 220ms ease;
        background: linear-gradient(
            to top,
            rgba(11, 33, 57, 0.9),
            rgba(11, 33, 57, 0.1)
        );
    }

    .gallery-trigger:hover .gallery-overlay,
    .gallery-trigger:focus-visible .gallery-overlay {
        opacity: 1;
    }

    .gallery-item figcaption {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 12px 14px 14px;
    }

    .gallery-item figcaption strong {
        font-size: 0.94rem;
        color: var(--gallery-text);
    }

    .gallery-item figcaption span {
        font-size: 0.82rem;
        color: var(--gallery-muted);
    }

    .gallery-empty {
        text-align: center;
        color: var(--gallery-muted);
        padding: 36px 0 50px;
    }

    .lightbox {
        border: 0;
        background: transparent;
        width: 100vw;
        height: 100dvh;
        max-width: 100vw;
        max-height: 100dvh;
        padding: 0;
        position: fixed;
    }

    .lightbox::backdrop {
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(3px);
    }

    .lightbox-figure {
        margin: 0;
        width: 100%;
        height: 100dvh;
        display: flex;
        padding: 58px 70px 24px;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    #lightbox-img {
        max-width: 100%;
        max-height: calc(100dvh - 130px);
        object-fit: contain;
        border-radius: 8px;
    }

    .lightbox-caption {
        color: #dde4ea;
        margin-top: 10px;
        text-align: center;
    }

    .lightbox-close,
    .lightbox-nav {
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        cursor: pointer;
    }

    .lightbox-close {
        position: fixed;
        top: 14px;
        right: 16px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        font-size: 1.3rem;
    }

    .lightbox-nav {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        width: 52px;
        height: 52px;
        border-radius: 50%;
        font-size: 2rem;
        line-height: 1;
    }

    .lightbox-prev {
        left: 16px;
    }
    .lightbox-next {
        right: 16px;
    }

    .lightbox-nav:disabled {
        opacity: 0.25;
        cursor: not-allowed;
    }

    .lightbox-close:focus-visible,
    .lightbox-nav:focus-visible {
        outline: 3px solid #fff;
        outline-offset: 2px;
    }

    @media (max-width: 640px) {
        .gallery-grid {
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: 12px;
        }

        .gallery-img {
            height: 190px;
        }

        .lightbox-figure {
            padding: 52px 12px 20px;
        }

        .lightbox-nav {
            display: none;
        }
    }
</style>

<script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const items = document.querySelectorAll<HTMLElement>(".gallery-item");
    const emptyMsg = document.getElementById("gallery-empty");

    filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter || "all";

            filterBtns.forEach((b) => {
                b.classList.remove("active");
                b.setAttribute("aria-pressed", "false");
            });

            btn.classList.add("active");
            btn.setAttribute("aria-pressed", "true");

            let visibleCount = 0;
            items.forEach((item) => {
                const isMatch =
                    filter === "all" || item.dataset.category === filter;
                item.hidden = !isMatch;
                if (isMatch) visibleCount += 1;
            });

            if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
        });
    });

    const lightbox = document.getElementById("lightbox") as HTMLDialogElement | null;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const lbCaption = document.getElementById("lightbox-caption");
    const lbClose = document.getElementById("lightbox-close");
    const lbPrev = document.getElementById("lightbox-prev") as HTMLButtonElement | null;
    const lbNext = document.getElementById("lightbox-next") as HTMLButtonElement | null;

    let currentIndex = 0;

    function getVisibleTriggers() {
        return Array.from(document.querySelectorAll(".gallery-trigger")).filter(
            (t) => !((t.closest(".gallery-item") as HTMLElement | null)?.hidden),
        );
    }

    function openLightbox(index: number) {
        const visible = getVisibleTriggers();
        if (index < 0 || index >= visible.length) return;

        currentIndex = index;
        const trigger = visible[index];
        const img = trigger.querySelector("img") as HTMLImageElement | null;
        const captionEl = trigger
            .closest(".gallery-item")
            ?.querySelector("figcaption");

        if (!img || !lbImg || !lbCaption || !lbPrev || !lbNext || !lightbox)
            return;

        lbImg.src = img.src;
        lbImg.alt = img.alt;
        lbCaption.textContent = captionEl?.textContent?.trim() || "";

        lbPrev.disabled = index === 0;
        lbNext.disabled = index === visible.length - 1;

        lightbox.showModal();
    }

    document.querySelectorAll(".gallery-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => {
            const visible = getVisibleTriggers();
            const visibleIndex = visible.indexOf(trigger);
            if (visibleIndex !== -1) openLightbox(visibleIndex);
        });
    });

    lbClose?.addEventListener("click", () => lightbox?.close());
    lbPrev?.addEventListener(
        "click",
        () => currentIndex > 0 && openLightbox(currentIndex - 1),
    );
    lbNext?.addEventListener("click", () => {
        const visible = getVisibleTriggers();
        if (currentIndex < visible.length - 1) openLightbox(currentIndex + 1);
    });

    lightbox?.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft" && !lbPrev?.disabled) lbPrev?.click();
        if (e.key === "ArrowRight" && !lbNext?.disabled) lbNext?.click();
    });

    lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) lightbox.close();
    });

    let touchStartX = 0;
    lightbox?.addEventListener(
        "touchstart",
        (e) => {
            touchStartX = e.touches[0].clientX;
        },
        { passive: true },
    );

    lightbox?.addEventListener(
        "touchend",
        (e) => {
            const delta = e.changedTouches[0].clientX - touchStartX;
            if (Math.abs(delta) > 50) {
                if (delta < 0) lbNext?.click();
                else lbPrev?.click();
            }
        },
        { passive: true },
    );
</script>
