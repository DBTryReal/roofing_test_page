---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

// 1. Consumir la colección de contenido de Astro de forma síncrona/reactiva en build-time
const allProjects = await getCollection("gallery");

// 2. Ordenar las imágenes de forma centralizada usando el campo "order" o "date"
const sortedProjects = allProjects.sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  return orderA - orderB;
});

// 3. Extraer categorías del conjunto para los botones de filtrado de manera dinámica
const categories = [...new Set(sortedProjects.map((project) => project.data.category))];
---

<BaseLayout
  title="Galería Dinámica de Proyectos de Techado"
  description="Galería reactiva de proyectos de techados, generada desde nuestro sistema de gestión de contenidos (CMS)."
>
  <header class="gallery-header container">
    <h1>Galería Dinámica de Proyectos</h1>
    <p>
      Estructura impulsada por Content Collections de Astro. Mantenimiento sencillo gracias a archivos individuales de Markdown.
    </p>
  </header>

  <!-- Filtro Dinámico -->
  <nav class="gallery-filters container" aria-label="Filtrado dinámico de proyectos">
    <button class="filter-btn active" data-filter="all" aria-pressed="true">
      Todos ({sortedProjects.length})
    </button>
    {
      categories.map((cat) => (
        <button class="filter-btn" data-filter={cat} aria-pressed="false">
          {cat.charAt(0).toUpperCase() + cat.slice(1)} ({sortedProjects.filter((p) => p.data.category === cat).length})
        </button>
      ))
    }
  </nav>

  <!-- Grilla de Imágenes Dinámica -->
  <main class="container">
    <ul class="gallery-grid" id="gallery-grid">
      {
        sortedProjects.map((project, index) => (
          <li class="gallery-item" data-category={project.data.category}>
            <article>
              <button
                class="gallery-trigger"
                aria-label={`Ampliar imagen: ${project.data.title} en ${project.data.location}`}
                data-index={index}
              >
                <!--
                  Astro procesa inteligentemente project.data.image gracias a
                  la función image() en the schema del content config
                -->
                <Image
                  src={project.data.image}
                  alt={project.data.alt}
                  width={600}
                  height={450}
                  loading={index < 3 ? "eager" : "lazy"}
                  decoding="async"
                  class="gallery-img"
                />
                <span class="gallery-overlay" aria-hidden="true">
                  <span class="overlay-title">{project.data.title}</span>
                  <span class="overlay-location">{project.data.location}</span>
                </span>
              </button>
              <div class="gallery-caption">
                <strong>{project.data.title}</strong>
                <span>{project.data.location}</span>
                {project.body && <p class="project-brief">{project.body.trim()}</p>}
              </div>
            </article>
          </li>
        ))
      }
    </ul>

    <!-- State vacío -->
    <div class="gallery-empty" id="gallery-empty" aria-live="polite" hidden>
      <p>No se encontraron proyectos correspondientes a este filtro en este momento.</p>
    </div>
  </main>

  <!-- Modulo Lightbox -->
  <dialog class="lightbox" id="lightbox" aria-modal="true" aria-label="Visor ampliado de imágenes">
    <div class="lightbox-container">
      <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar visor">✕</button>
      
      <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Imagen anterior">‹</button>
      
      <figure class="lightbox-figure">
        <img
          id="lightbox-img"
          src=""
          alt=""
          width="1200"
          height="900"
          decoding="async"
        />
        <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
      </figure>
      
      <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Imagen siguiente">›</button>
    </div>
  </dialog>
</BaseLayout>

<style>
  /* ──── ESTILOS DE LA GALERÍA (OPCIÓN B: Featured + Grid Dinámico) ──── */
  .gallery-header {
    text-align: center;
    padding: 60px 0 30px;
  }
  .gallery-header h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .gallery-header p {
    font-size: 1.125rem;
    color: #4a5568;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .gallery-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: 40px;
  }
  .filter-btn {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: #4a5568;
    background: #edf2f7;
    border: 2px solid transparent;
    padding: 10px 22px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .filter-btn:hover {
    background: #e2e8f0;
    color: #2d3748;
  }
  .filter-btn.active, .filter-btn[aria-pressed="true"] {
    background: #2b6cb0;
    color: #ffffff;
  }
  .filter-btn:focus-visible {
    outline: 3px solid #3182ce;
    outline-offset: 2px;
  }

  /* OPCIÓN DE VISUALIZACIÓN B: Grid Mixto con Características Destacadas (First-child featured) */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    padding: 0;
    margin: 0 0 60px;
    list-style: none;
  }

  .gallery-item {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    height: 100%;
  }
  .gallery-item:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
  }
  .gallery-item[hidden] {
    display: none !important;
  }

  /* El primer proyecto (si contiene el atributo featured de forma física) se resalta */
  @media (min-width: 992px) {
    .gallery-item:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }
    .gallery-item:first-child .gallery-img {
      height: 570px;
    }
  }

  .gallery-trigger {
    position: relative;
    width: 100%;
    border: none;
    background: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    display: block;
    overflow: hidden;
    background-color: #f7fafc;
  }
  .gallery-trigger:focus-visible {
    outline: 3px solid #3182ce;
    outline-offset: -3px;
  }

  .gallery-img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-trigger:hover .gallery-img,
  .gallery-trigger:focus-visible .gallery-img {
    transform: scale(1.08);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(43, 108, 176, 0) 40%, rgba(43, 108, 176, 0.9) 100%);
    opacity: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 24px;
    text-align: left;
    transition: opacity 0.3s ease;
  }
  .gallery-trigger:hover .gallery-overlay,
  .gallery-trigger:focus-visible .gallery-overlay {
    opacity: 1;
  }
  .overlay-title {
    color: #ffffff;
    font-size: 1.15rem;
    font-weight: 700;
  }
  .overlay-location {
    color: #ebf8ff;
    font-size: 0.9rem;
    margin-top: 4px;
  }

  .gallery-caption {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .gallery-caption strong {
    color: #2d3748;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .gallery-caption span {
    color: #4a5568;
    font-size: 0.85rem;
  }
  .project-brief {
    color: #718096;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 8px 0 0 0;
    border-top: 1px dashed #e2e8f0;
    padding-top: 8px;
    white-space: pre-line;
  }

  .gallery-empty {
    text-align: center;
    padding: 80px 20px;
    background: #edf2f7;
    border-radius: 12px;
    color: #4a5568;
    font-weight: 500;
    margin-bottom: 60px;
  }

  /* ──── DIALOG / LIGHTBOX CSS (Compatibilidad de visualización) ──── */
  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: fixed;
    inset: 0;
  }
  .lightbox::backdrop {
    background: rgba(10, 17, 40, 0.95);
    backdrop-filter: blur(8px);
  }
  .lightbox-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-sizing: border-box;
  }

  .lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    max-width: 90vw;
    max-height: 90vh;
  }
  #lightbox-img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    background: rgba(0,0,0,0.2);
  }
  .lightbox-caption {
    color: #cbd5e0;
    margin-top: 20px;
    font-size: 1rem;
    text-align: center;
    font-weight: 500;
    max-width: 600px;
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-size: 2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, opacity 0.2s;
    z-index: 10;
  }
  .lightbox-prev { left: 24px; }
  .lightbox-next { right: 24px; }
  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.25); }
  .lightbox-nav:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  @media (max-width: 991px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .lightbox-nav {
      display: none;
    }
  }
</style>

<script>
  // ── SCRIPT IDÉNTICO AL MODULAR CON SOPORTE COMPLETO DE ACCESIBILIDAD ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const gridItems = document.querySelectorAll<HTMLElement>(".gallery-item");
  const emptyMessage = document.getElementById("gallery-empty")!;

  // Filtro
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selectedFilter = btn.dataset.filter!;
      filterBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");

      let matches = 0;
      gridItems.forEach((item) => {
        const itemCategory = item.dataset.category!;
        const isSelected = selectedFilter === "all" || itemCategory === selectedFilter;
        item.hidden = !isSelected;
        if (isSelected) matches++;
      });
      emptyMessage.hidden = matches > 0;
    });
  });

  // Lightbox
  const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lbCaption = document.getElementById("lightbox-caption")!;
  const lbClose = document.getElementById("lightbox-close")!;
  const lbPrev = document.getElementById("lightbox-prev") as HTMLButtonElement;
  const lbNext = document.getElementById("lightbox-next") as HTMLButtonElement;

  let currentIndex = 0;

  function getVisibleTriggers(): HTMLButtonElement[] {
    return Array.from(document.querySelectorAll<HTMLButtonElement>(".gallery-trigger"))
      .filter((trigger) => {
        const item = trigger.closest(".gallery-item") as HTMLElement;
        return item && !item.hidden;
      });
  }

  function renderImage(index: number) {
    const triggers = getVisibleTriggers();
    if (index < 0 || index >= triggers.length) return;
    currentIndex = index;

    const currentTrigger = triggers[index];
    const imageInside = currentTrigger.querySelector("img")!;
    const itemEl = currentTrigger.closest(".gallery-item")!;
    const captionSpan = itemEl.querySelector(".gallery-caption")!;

    lbImg.src = imageInside.src;
    lbImg.alt = imageInside.alt;
    
    // Obtenemos título y locación, omitiendo la descripción breve externa para un caption limpio
    const titleText = captionSpan.querySelector("strong")?.textContent ?? "";
    const locationText = captionSpan.querySelector("span")?.textContent ?? "";
    lbCaption.textContent = `${titleText} - ${locationText}`;

    lbPrev.disabled = currentIndex === 0;
    lbNext.disabled = currentIndex === triggers.length - 1;

    if (lbPrev.disabled && document.activeElement === lbPrev) {
      lbNext.focus();
    } else if (lbNext.disabled && document.activeElement === lbNext) {
      lbPrev.focus();
    }
  }

  function openLightbox(index: number) {
    renderImage(index);
    document.body.style.overflow = "hidden";
    lightbox.showModal();
  }

  function closeLightbox() {
    lightbox.close();
    document.body.style.overflow = "";
    const triggers = getVisibleTriggers();
    if (triggers[currentIndex]) {
      triggers[currentIndex].focus();
    }
  }

  document.querySelectorAll<HTMLButtonElement>(".gallery-trigger").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const triggers = getVisibleTriggers();
      const realIndex = triggers.indexOf(trigger);
      if (realIndex !== -1) openLightbox(realIndex);
    });
  });

  lbClose.addEventListener("click", closeLightbox);
  lightbox.addEventListener("close", closeLightbox);

  lbPrev.addEventListener("click", () => {
    if (currentIndex > 0) renderImage(currentIndex - 1);
  });

  lbNext.addEventListener("click", () => {
    const triggers = getVisibleTriggers();
    if (currentIndex < triggers.length - 1) renderImage(currentIndex + 1);
  });

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  lightbox.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft" && !lbPrev.disabled) {
      lbPrev.click();
    } else if (e.key === "ArrowRight" && !lbNext.disabled) {
      lbNext.click();
    }
  });

  let touchStartX = 0;
  lightbox.addEventListener("touchstart", (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  lightbox.addEventListener("touchend", (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchEndX - touchStartX;

    if (Math.abs(diff) > 60) {
      if (diff < 0 && !lbNext.disabled) {
        lbNext.click();
      } else if (diff > 0 && !lbPrev.disabled) {
        lbPrev.click();
      }
    }
  }, { passive: true });
</script>