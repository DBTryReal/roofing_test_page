---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Home"
	description="Sitio web sobre Roofing y construcción en Carolina del Norte"
>
	<div class="content page-content">
		<section class="hero">
			<h1>Creamos experiencias digitales que importan</h1>
			<p class="hero-subtitle">
				Diseño web, posicionamiento SEO e identidad de marca para
				negocios que quieren destacar.
			</p>
			<div class="hero-actions">
				<a href="/services" class="btn-primary">Ver servicios</a>
				<a href="/contact" class="btn-secondary">Contáctanos</a>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.hero {
		padding: 80px 0 60px;
		text-align: center;
	}
	.hero h1 {
		font-size: 2.8rem;
		font-weight: 700;
		line-height: 1.15;
		color: #1a1a1a;
		margin-bottom: 20px;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
	}
	.hero-subtitle {
		font-size: 1.15rem;
		color: #666;
		max-width: 520px;
		margin: 0 auto 36px;
		line-height: 1.6;
	}
	.hero-actions {
		display: flex;
		gap: 16px;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-primary {
		/* background-color: #7c3aed; */
		background-color: #395ca0;
		color: #fff;
		padding: 12px 28px;
		border-radius: 6px;
		font-weight: 600;
		font-size: 1rem;
		transition: background-color 0.2s;
	}
	.btn-primary:hover {
		/* background-color: #5b21b6; */
		background-color: #293a8b;
		color: #fff;
	}
	.btn-secondary {
		background-color: transparent;
		/* color: #7c3aed; */
		color: #395ca0;
		padding: 12px 28px;
		/* border: 2px solid #7c3aed; */
		border: 2px solid #395ca0;
		border-radius: 6px;
		font-weight: 600;
		font-size: 1rem;
		transition:
			background-color 0.2s,
			color 0.2s;
	}
	.btn-secondary:hover {
		background-color: #f9f6fc;
	}
</style>
