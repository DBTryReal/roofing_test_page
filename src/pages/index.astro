---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

// 1. ASSET & MEDIA IMPORTS
import heroImg from "../assets/images/image1.webp";
import aboutImg from "../assets/images/image2.webp";

// 2. DYNAMIC SERVICE DATA (Scalability & Maintainability)
const services = await getCollection("services");
const featuredServices = services
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.slice(0, 4); // Show only the top 4 on Home

const allGallery = await getCollection("gallery");
const recentProjects = allGallery
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.slice(0, 4);
---

<BaseLayout
	title="Home - Roofing & Construction Experts in North Carolina"
	description="Professional roofing, repair, and residential & commercial construction by Carolina Prime Construction & Remodeling LLC. Free quotes across NC."
>
	<!-- ============================================================
     HERO SECTION WITH BACKGROUND IMAGE AND FALLBACK (PERFORMANCE & UX)
     ============================================================ -->
	<section
		class="hero-container"
		aria-label="Welcome — roofing services overview"
	>
		<div class="image-overlay" aria-hidden="true"></div>
		<Image
			src={heroImg}
			alt="Aerial view of a professional roofing crew installing a residential roof in North Carolina"
			width={1200}
			height={600}
			quality={80}
			loading="eager"
			class="hero-image"
		/>

		<div class="hero-content container">
			<span class="hero-badge"
				>Carolina Prime Construction & Remodeling LLC</span
			>
			<h1>Premium Roofing Protection & Design for Your Home</h1>
			<p>
				Top-quality roof installation, corrective maintenance, and
				structural solutions across North Carolina. Trusted
				professionals with a proven track record.
			</p>
			<div class="hero-actions">
				<a
					href={`${import.meta.env.BASE_URL}contact`}
					class="btn-primary"
					aria-label="Request a free roofing inspection"
				>
					Free Inspection →
				</a>
				<a
					href={`${import.meta.env.BASE_URL}services`}
					class="btn-secondary"
					aria-label="View all our services"
				>
					Our Services
				</a>
			</div>
		</div>
	</section>

	<!-- ============================================================
     TRUST BANNER / KEY DIFFERENTIATORS (ACCESSIBILITY & A11Y)
     ============================================================ -->
	<section class="trust-banner" aria-label="Key reasons to trust us">
		<div class="container grid-trust">
			<div class="trust-item">
				<div class="icon-wrap">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
						></path>
					</svg>
				</div>
				<div>
					<h3>100% Insured & Certified</h3>
					<p>Licensed to operate throughout North Carolina.</p>
				</div>
			</div>

			<div class="trust-item">
				<div class="icon-wrap">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
						></path>
					</svg>
				</div>
				<div>
					<h3>On Time, Every Time</h3>
					<p>
						Fast responses and firm quotes delivered within 24
						hours.
					</p>
				</div>
			</div>

			<div class="trust-item">
				<div class="icon-wrap">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
						></path>
					</svg>
				</div>
				<div>
					<h3>Written Professional Warranty</h3>
					<p>Premium materials backed by a written guarantee.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ============================================================
     WHAT WE DO (DYNAMIC SERVICES FROM CONTENT COLLECTIONS)
     ============================================================ -->
	<section class="services-teaser container">
		<div class="section-header-cnt">
			<span class="sec-subtitle">Our Expertise</span>
			<h2>Professional Construction Services</h2>
			<p class="section-desc">
				We deliver comprehensive roof installation and repair solutions
				engineered to withstand the demanding climate conditions of the
				southeastern United States.
			</p>
		</div>

		<div class="services-grid">
			{
				featuredServices.map((service) => (
					<article class="service-teaser-card">
						<div class="service-media-icon">
							{service.data.icon}
						</div>
						<div class="service-body">
							<h3>{service.data.title}</h3>
							<p>{service.data.tagline}</p>
							<div class="card-footer">
								<span class="service-badge-tag">
									Guaranteed
								</span>
								<a
									href={`${import.meta.env.BASE_URL}services/${service.id}`}
									class="text-link"
									aria-label={`Learn more about ${service.data.title}`}
								>
									Learn more →
								</a>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<!-- ============================================================
     ABOUT US (EXPERIENCE & STORY WITH "image2.webp")
     ============================================================ -->
	<section class="about-highlight">
		<div class="container grid-about">
			<div class="about-media">
				<Image
					src={aboutImg}
					alt="Carolina Prime Construction & Remodeling LLC professionals working on the roof structure of a residential project"
					width={600}
					height={450}
					quality={80}
					loading="lazy"
				/>
				<div class="badge-stat">
					<span class="stat-number">10+</span>
					<span class="stat-text">Years Protecting Homes in NC</span>
				</div>
			</div>
			<div class="about-text">
				<span class="sec-subtitle">Who We Are</span>
				<h2>Absolute Commitment. Quality Without Shortcuts.</h2>
				<p>
					At <strong
						>Carolina Prime Construction & Remodeling LLC</strong
					>, your peace of mind is our top priority. We firmly believe
					a roof is far more than shingles — it is the protection that
					shelters the families and businesses building the future of
					our community.
				</p>
				<p>
					With every project, we deliver aesthetic precision, key
					structural safety standards, and on-time completion. We
					manage the entire process from start to finish, including
					permitting and insurance coordination.
				</p>
				<ul class="bullets-check">
					<li>
						<svg
							class="check-svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							aria-hidden="true"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M5 13l4 4L19 7"></path></svg
						>
						Top-rated, long-lasting materials (shingles and metal).
					</li>
					<li>
						<svg
							class="check-svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							aria-hidden="true"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M5 13l4 4L19 7"></path></svg
						>
						Highly skilled local engineers and craftsmen.
					</li>
					<li>
						<svg
							class="check-svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							aria-hidden="true"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M5 13l4 4L19 7"></path></svg
						>
						Thorough cleanup and post-project inspection included.
					</li>
				</ul>
				<a
					href={`${import.meta.env.BASE_URL}about`}
					class="btn-primary alt-btn">Meet Our Team</a
				>
			</div>
		</div>
	</section>

	<!-- ============================================================
     PROJECT GALLERY (VISUAL ENGAGEMENT & INTERACTION)
     ============================================================ -->
	<section class="gallery-teaser container">
		<div class="section-header-cnt">
			<span class="sec-subtitle">Recent Projects</span>
			<h2>Real results we're genuinely proud of</h2>
			<p class="section-desc">
				Real homes transformed and protected. Browse our interactive
				grid and see the craftsmanship and durability behind every
				finish.
			</p>
		</div>

		<!-- Interactive project grid -->
		<div class="gallery-interactive-grid">
			{
				recentProjects.map((proj) => (
					<div class="proj-card-wrap">
						<figure class="proj-card">
							<div class="proj-img-box">
								<Image
									src={proj.data.image}
									alt={proj.data.alt}
									width={500}
									height={380}
									quality={85}
									loading="lazy"
									class="p-img"
								/>
								<div class="proj-overlay">
									<div class="overlay-details">
										<span class="proj-location">
											{proj.data.location}
										</span>
										<h3 class="proj-title">
											{proj.data.title}
										</h3>
									</div>
								</div>
							</div>
						</figure>
					</div>
				))
			}
		</div>

		<div class="gallery-cta">
			<a
				href={`${import.meta.env.BASE_URL}gallery`}
				class="btn-primary"
				aria-label="View the full project gallery"
			>
				View Full Project Gallery
			</a>
		</div>
	</section>

	<!-- ============================================================
     HOW WE WORK (STEP-BY-STEP / REDUCING FRICTION)
     ============================================================ -->
	<section class="workflow-section">
		<div class="container">
			<div class="section-header-cnt centered">
				<span class="sec-subtitle">Transparent Process</span>
				<h2>Your path to a safe roof, step by step</h2>
			</div>

			<div class="steps-grid">
				<div class="step-card">
					<span class="step-num">01</span>
					<h3>Free Initial Inspection</h3>
					<p>
						A certified engineer assesses the real condition and
						critical areas of your roof — completely free of charge.
					</p>
				</div>

				<div class="step-card">
					<span class="step-num">02</span>
					<h3>Transparent Quote</h3>
					<p>
						We break down the estimate line by line, recommending
						the best technical solution with zero hidden costs.
					</p>
				</div>

				<div class="step-card">
					<span class="step-num">03</span>
					<h3>Fast, Clean Build</h3>
					<p>
						We execute the installation while minimizing disruption
						and strictly honoring agreed timelines.
					</p>
				</div>

				<div class="step-card">
					<span class="step-num">04</span>
					<h3>Delivery & Cleanup</h3>
					<p>
						We run a magnetic nail sweep, remove all debris, and
						issue your official materials warranty.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ============================================================
     FINAL CTA BANNER (TRAFFIC CONVERTER)
     ============================================================ -->
	<section class="cta-banner container">
		<div class="cta-banner-box">
			<div class="cta-text-cnt">
				<h2>Worried about leaks or recent storm damage?</h2>
				<p>
					Don't wait any longer. Silent water damage destroys property
					value. Let us give you a no-obligation inspection today.
				</p>
			</div>
			<div class="cta-action-cnt">
				<a
					href={`${import.meta.env.BASE_URL}contact`}
					class="btn-primary btn-white-accent"
					>Schedule My Free Inspection</a
				>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ============================================================
     ESTILOS HERO SECTION CON CONTEXTO VISUAL (MUTED BACKGROUND VIDEO)
     ============================================================ */
	.hero-container {
		position: relative;
		width: 100%;
		min-height: 75vh; /* Altura generosa para Desktop */
		display: flex;
		align-items: center;
		overflow: hidden;
		color: #fff;
		background-color: #1a1a1a; /* Background de respaldo */
		padding: 100px 0;
	}

	/* La imagen ocupa todo el fondo dinámico */
	.hero-image {
		position: absolute;
		top: 50%;
		left: 50%;
		min-width: 100%;
		min-height: 100%;
		width: auto;
		height: auto;
		z-index: 1;
		transform: translate(-50%, -50%);
		/* object-fit: cover; */
		object-fit: contain;

		/* way 2 */
		/* 
		min-width: unset;
		min-height: unset;
		width: 100vh;
		height: 100vw;
		transform: translate(-50%, -50%) rotate(90deg);
		*/
	}

	/* .hero-fallback-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		z-index: 1;
		opacity: 0.15;
		filter: grayscale(20%);
	} */

	/* Overlay de degradado oscuro que garantiza el contraste WCAG 2.1 AAA de color */
	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			135deg,
			rgba(15, 23, 42, 0.9) 0%,
			rgba(26, 43, 76, 0.75) 50%,
			rgba(15, 23, 42, 0.4) 100%
		);
		z-index: 2;
	}

	/* Contenido legible gracias al z-index alto */
	.hero-content {
		position: relative;
		z-index: 3;
		max-width: 750px;
	}

	.hero-badge {
		display: inline-block;
		background-color: #395ca0;
		color: #fff;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 6px 14px;
		border-radius: 50px;
		margin-bottom: 24px;
		box-shadow: 0 4px 10px rgba(57, 92, 160, 0.4);
	}

	.hero-container h1 {
		font-size: 3.5rem;
		line-height: 1.15;
		font-weight: 700;
		margin-bottom: 20px;
		letter-spacing: -1px;
	}

	.hero-container p {
		font-size: 1.25rem;
		color: #e2e8f0;
		line-height: 1.6;
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	/* ============================================================
     ESTILOS DE BOTONES (UI/UX)
     ============================================================ */
	.btn-primary {
		background-color: #395ca0;
		color: #fff;
		padding: 14px 28px;
		border-radius: 6px;
		font-weight: 600;
		font-size: 1rem;
		border: none;
		cursor: pointer;
		box-shadow: 0 4px 15px rgba(57, 92, 160, 0.3);
		transition: all 0.25s ease;
		display: inline-block;
		text-align: center;
	}

	.btn-primary:hover {
		background-color: #293a8b;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(57, 92, 160, 0.45);
		color: #fff;
	}

	.btn-secondary {
		background-color: rgba(255, 255, 255, 0.1);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.3);
		padding: 14px 28px;
		border-radius: 6px;
		font-weight: 600;
		font-size: 1rem;
		transition: all 0.25s ease;
		display: inline-block;
		text-align: center;
		backdrop-filter: blur(5px);
	}

	.btn-secondary:hover {
		background-color: rgba(255, 255, 255, 0.2);
		border-color: #fff;
		color: #fff;
	}

	/* ============================================================
     BARRAN DE CONFIANZA (SERIEDAD DE MARCA)
     ============================================================ */
	.trust-banner {
		background-color: #f1f5f9;
		padding: 30px 0;
		border-bottom: 1px solid #e2e8f0;
	}

	.grid-trust {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 32px;
	}

	.trust-item {
		display: flex;
		align-items: flex-start;
		gap: 16px;
	}

	.icon-wrap {
		background-color: rgba(57, 92, 160, 0.1);
		color: #395ca0;
		padding: 10px;
		border-radius: 8px;
		flex-shrink: 0;
	}

	.icon-wrap svg {
		width: 24px;
		height: 24px;
	}

	.trust-item h3 {
		font-size: 1.1rem;
		font-weight: 600;
		color: #0f172a;
		margin-bottom: 4px;
	}

	.trust-item p {
		font-size: 0.9rem;
		color: #64748b;
		margin: 0;
	}

	/* ============================================================
     SECCIÓN DE SERVICIOS DINÁMICOS
     ============================================================ */
	.services-teaser {
		padding: 80px 24px;
	}

	.section-header-cnt {
		max-width: 650px;
		margin-bottom: 50px;
	}

	.section-header-cnt.centered {
		margin-left: auto;
		margin-right: auto;
		text-align: center;
	}

	.sec-subtitle {
		color: #395ca0;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		display: block;
		margin-bottom: 12px;
	}

	.section-header-cnt h2 {
		font-size: 2.25rem;
		color: #0f172a;
		font-weight: 700;
		line-height: 1.2;
		margin-bottom: 16px;
	}

	.section-desc {
		font-size: 1.1rem;
		color: #555;
		line-height: 1.6;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 24px;
	}

	.service-teaser-card {
		background-color: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 30px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
		transition: all 0.3s ease;
	}

	.service-teaser-card:hover {
		transform: translateY(-5px);
		box-shadow:
			0 20px 25px -5deg rgba(0, 0, 0, 0.08),
			0 10px 10px -5px rgba(0, 0, 0, 0.04);
		border-color: rgba(57, 92, 160, 0.3);
	}

	.service-media-icon {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.service-body h3 {
		font-size: 1.25rem;
		color: #0f172a;
		font-weight: 700;
		margin-bottom: 8px;
	}

	.service-body p {
		font-size: 0.95rem;
		color: #64748b;
		line-height: 1.5;
		margin-bottom: 24px;
	}

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 1px solid #f1f5f9;
		padding-top: 16px;
		margin-top: auto;
	}

	.service-badge-tag {
		background-color: #f0fdf4;
		color: #16a34a;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 4px 10px;
		border-radius: 4px;
	}

	.text-link {
		color: #395ca0;
		font-weight: 600;
		font-size: 0.9rem;
		transition: color 0.2s ease;
	}

	.text-link:hover {
		color: #293a8b;
	}

	/* ============================================================
     SECCIÓN SOBRE NOSOTROS (EXPERIENCIA E HISTORIA DE APOYO)
     ============================================================ */
	.about-highlight {
		background-color: #f8fafc;
		padding: 90px 24px;
		border-top: 1px solid #ebe5f2;
		border-bottom: 1px solid #ebe5f2;
	}

	.grid-about {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 60px;
		align-items: center;
	}

	.about-media {
		position: relative;
	}

	.about-media img {
		border-radius: 12px;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
		object-fit: cover;
		width: 100%;
		height: auto;
	}

	.badge-stat {
		position: absolute;
		bottom: -20px;
		right: -10px;
		background-color: #fff;
		padding: 20px;
		border-radius: 12px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
		display: flex;
		flex-direction: column;
		max-width: 180px;
		border-left: 5px solid #395ca0;
	}

	.stat-number {
		font-size: 2.25rem;
		font-weight: 700;
		color: #395ca0;
		line-height: 1;
		margin-bottom: 4px;
	}

	.stat-text {
		font-size: 0.8rem;
		font-weight: 600;
		color: #334155;
		line-height: 1.3;
	}

	.about-text h2 {
		font-size: 2.25rem;
		font-weight: 700;
		color: #0f172a;
		line-height: 1.2;
		margin-bottom: 24px;
	}

	.about-text p {
		font-size: 1.05rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 20px;
	}

