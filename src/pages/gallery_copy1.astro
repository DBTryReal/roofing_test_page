---
// ── 1. FRONTMATTER (bloque de servidor, corre en Node al compilar) ──────────
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

// Importar cada imagen como módulo. Astro las optimizará en el build.
// Los paths son RELATIVOS a este archivo.
import img1 from "../assets/images/gallery/proyecto-1.webp";
import img2 from "../assets/images/gallery/proyecto-2.webp";
import img3 from "../assets/images/gallery/proyecto-3.webp";
import img4 from "../assets/images/gallery/proyecto-4.webp";
import img5 from "../assets/images/gallery/proyecto-5.webp";
import img6 from "../assets/images/gallery/proyecto-6.webp";
import img7 from "../assets/images/gallery/proyecto-7.webp";

// Array de proyectos. Aquí defines los datos de cada tarjeta.
// Al agregar un proyecto nuevo solo añades un objeto a este array.
const projects = [
  {
    id: "p1",
    src: img1,
    alt: "Techo residencial reparado y reforzado en Charlotte, NC",
    title: "Reparación residencial",
    location: "Charlotte, NC",
    category: "reparacion",
    categoryLabel: "Reparación",
  },
  {
    id: "p2",
    src: img2,
    alt: "Instalación de techo nuevo con acabado moderno en Raleigh, NC",
    title: "Instalación nueva",
    location: "Raleigh, NC",
    category: "instalacion",
    categoryLabel: "Instalación",
  },
  {
    id: "p3",
    src: img3,
    alt: "Mantenimiento preventivo de techo plano en Durham, NC",
    title: "Mantenimiento preventivo",
    location: "Durham, NC",
    category: "mantenimiento",
    categoryLabel: "Mantenimiento",
  },
  {
    id: "p4",
    src: img4,
    alt: "Reparación de daños por granizo en techo residencial, Greensboro NC",
    title: "Daños por granizo",
    location: "Greensboro, NC",
    category: "reparacion",
    categoryLabel: "Reparación",
  },
  {
    id: "p5",
    src: img5,
    alt: "Instalación completa de techo de asfalto con aislamiento en Cary, NC",
    title: "Techo de asfalto",
    location: "Cary, NC",
    category: "instalacion",
    categoryLabel: "Instalación",
  },
  {
    id: "p6",
    src: img6,
    alt: "Inspección y mantenimiento de canaletas en Winston-Salem, NC",
    title: "Limpieza de canaletas",
    location: "Winston-Salem, NC",
    category: "mantenimiento",
    categoryLabel: "Mantenimiento",
  },
  {
    id: "p7",
    src: img7,
    alt: "Mantenimiento de techo en Raleigh, NC",
    title: "Mantenimiento de techo",
    location: "Raleigh, NC",
    category: "mantenimiento",
    categoryLabel: "Mantenimiento",
  }
];
---

<!-- ── 2. TEMPLATE HTML ─────────────────────────────────────────────────── -->

<!--
  BaseLayout envuelve todo en <html><head><body>.
  Le pasamos title y description para el <head> (SEO).
-->
<BaseLayout
  title="Galería de proyectos"
  description="Trabajos recientes de reparación, instalación y mantenimiento de techos en Carolina del Norte."
>

  <!-- ── SECCIÓN INTRO ──────────────────────────────────────────────────── -->
  <!--
    role="banner" lo tiene el <header> en BaseLayout.
    Este <section> es contenido de página, aria-labelledby conecta
    el título con la región para lectores de pantalla.
  -->
  <section class="gallery-intro" aria-labelledby="gallery-heading">
    <h2 id="gallery-heading">Proyectos recientes</h2>
    <p>
      Explora algunos de nuestros trabajos destacados en reparación,
      instalación y mantenimiento en Carolina del Norte.
    </p>
  </section>

  <!-- ── FILTROS DE CATEGORÍA ───────────────────────────────────────────── -->
  <!--
    role="group" agrupa los botones semánticamente.
    aria-label describe el grupo al lector de pantalla.
    data-filter es el atributo que JS leerá para filtrar.
    aria-pressed indica si el botón está activo (para accesibilidad).
    La clase "active" controla el estilo visual del botón seleccionado.
  -->
  <div class="gallery-filters" role="group" aria-label="Filtrar proyectos por categoría">
    <button class="filter-btn active" data-filter="todos" aria-pressed="true">
      Todos
    </button>
    <button class="filter-btn" data-filter="reparacion" aria-pressed="false">
      Reparación
    </button>
    <button class="filter-btn" data-filter="instalacion" aria-pressed="false">
      Instalación
    </button>
    <button class="filter-btn" data-filter="mantenimiento" aria-pressed="false">
      Mantenimiento
    </button>
  </div>

  <!-- ── GRID DE IMÁGENES ───────────────────────────────────────────────── -->
  <!--
    role="list" + role="listitem" en cada <figure> porque usamos
    <figure> como elemento de lista (semántica para a11y).
    data-category en cada <figure> es lo que JS compara con data-filter.
    aria-live="polite" anuncia a lectores de pantalla cuando
    la lista cambia al filtrar (el texto de conteo en el span de abajo).
  -->
  <div
    class="gallery-grid"
    id="gallery-grid"
    role="list"
    aria-label="Proyectos de techos"
  >
    <!--
      projects.map() itera el array y genera un <figure> por proyecto.
      El JSX dentro del frontmatter ({}) es procesado en el servidor (SSG).
    -->
    {projects.map((project) => (
      <figure
        class="gallery-item"
        data-category={project.category}
        role="listitem"
      >
        <!--
          Usamos <button> en lugar de <div> o <a> para abrir el lightbox.
          <button> es focusable por teclado y activable con Enter/Space
          sin necesidad de JS extra. Es la práctica correcta de a11y.

          data-src almacena la URL final de la imagen optimizada por Astro.
          La necesitamos para pasársela al lightbox con JS.
          project.src.src es la propiedad del objeto ImageMetadata de Astro
          que contiene el path de salida del build.

          data-alt y data-title los usará el lightbox para el caption.
        -->
        <button
          class="gallery-trigger"
          aria-label={`Ver imagen completa: ${project.title} en ${project.location}`}
          data-src={project.src.src}
          data-alt={project.alt}
          data-title={project.title}
          data-location={project.location}
        >
          <!--
            <Image> de astro:assets. Diferente de <img> HTML puro.
            - src: el objeto importado (no un string)
            - alt: OBLIGATORIO, descriptivo para SEO y a11y
            - width/height: Astro los usa para calcular el aspect-ratio
              y evitar CLS. No significa que la imagen se muestre en ese tamaño.
            - loading="lazy": no carga hasta que entra al viewport
            - decoding="async": no bloquea el hilo principal al decodificar
            - class: CSS class para estilos
          -->
          <Image
            src={project.src}
            alt={project.alt}
            width={800}
            height={600}
            loading="lazy"
            decoding="async"
            class="gallery-img"
          />
          <!--
            Overlay visible al hacer hover.
            aria-hidden="true" porque es puramente decorativo.
          -->
          <div class="gallery-overlay" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11---12" cy="12" r="3"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
        </button>
        <figcaption class="gallery-caption">
          <strong>{project.title}</strong>
          <span class="gallery-location">{project.location}</span>
        </figcaption>
      </figure>
    ))}
  </div>