---
// CORE CONCEPT:
// getCollection("services") loads ALL .md files from the collection.
// Returns an array of objects, one per .md file.
// Here we sort them by the "order" field in the frontmatter.

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";

// Load all .md service files and sort them
const services = await getCollection("services");

// Sort by the "order" frontmatter field (ascending)
// Files without an order value are pushed to the end
const sortedServices = services.sort((a, b) => {
    const orderA = a.data.order ?? 999;
    const orderB = b.data.order ?? 999;
    return orderA - orderB;
});
---

<BaseLayout
    title="Roofing Services"
    description="Professional roofing installation, repair, and commercial roofing services in North Carolina."
>
    <!-- PAGE HERO -->
    <section class="page-hero">
        <div class="container">
            <span class="sec-subtitle">Our Expertise</span>
            <h1>Professional Roofing Services</h1>
            <p>
                Comprehensive residential and commercial roofing solutions to
                protect your property across North Carolina.
            </p>
        </div>
    </section>

    <!-- SERVICES LISTING -->
    <section class="services-listing container">
        <div class="section-header-cnt">
            <span class="sec-subtitle">What We Offer</span>
            <h2>All Our Services</h2>
            <p class="section-desc">
                Every service includes a free initial inspection, certified
                materials, and a written labor warranty.
            </p>
        </div>

        <div class="services-grid">
            {sortedServices.map((service) => <ServiceCard service={service} />)}
        </div>

        {
            sortedServices.length < 1 && (
                <p class="empty-message">
                    No services available at the moment.
                </p>
            )
        }
    </section>

    <!-- CTA BANNER -->
    <section class="cta-banner container">
        <div class="cta-banner-box">
            <div class="cta-text-cnt">
                <h2>Ready to protect your property?</h2>
                <p>
                    We'll perform a free inspection and deliver a detailed quote
                    in less than 24 hours.
                </p>
            </div>
            <div class="cta-action-cnt">
                <a
                    href={`${import.meta.env.BASE_URL}contact`}
                    class="btn-white-accent"
                >
                    Schedule My Free Inspection
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* PAGE HERO */
    .page-hero {
        background-color: #0f172a;
        color: #fff;
        padding: 80px 24px;
    }

    .page-hero .sec-subtitle {
        color: #395ca0;
        font-size: 0.85rem;
        font-weight: 700;
