        letter-spacing: 2px;
        display: block;
        margin-bottom: 12px;
    }

    .page-hero h1 {
        font-size: 2.75rem;
        font-weight: 700;
        line-height: 1.15;
        margin-bottom: 20px;
        letter-spacing: -1px;
    }

    .page-hero p {
        font-size: 1.15rem;
        color: #cbd5e1;
