---
//
// CONCEPTO CLAVE — getStaticPaths():
// Astro es un generador de sitios estáticos. Necesita saber de antemano
// cuántas páginas va a generar y cuál es la URL de cada una.
//
// getStaticPaths() le dice a Astro:
//   "Para cada archivo .md que encuentres, crea una página en /services/{id}"
//
// params: { id: service.id }   →  el valor entre [] en la URL
//   instalacion-residencial.md →  params.id = "instalacion-residencial" →  URL: /services/instalacion-residencial
//   reparacion-goteras.md      →  params.id = "reparacion-goteras"      →  URL: /services/reparacion-goteras
//   techado-comercial.md       →  params.id = "techado-comercial"       →  URL: /services/techado-comercial
//   techos-de-metal.md         →  params.id = "techos-de-metal"         →  URL: /services/techos-de-metal
//
// props: { service }  →  datos disponibles en Astro.props dentro de la página

import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const services = await getCollection("services");

    return services.map((service) => ({
        params: { id: service.id }, // "web-design", "seo", "branding"
        props: { service },
    }));
}

// Recibir el servicio como prop (definido arriba en getStaticPaths)
const { service } = Astro.props;

// Convertir el markdown del cuerpo a componente HTML
const { Content } = await render(service);
---

<BaseLayout title={`${service.data.title}`} description={service.data.tagline}>
    <!-- HERO DE PÁGINA -->
    <section class="page-hero">
        <div class="container">
            <a href={`${import.meta.env.BASE_URL}services`} class="back-link"
                >← Todos los servicios</a
            >
            <div class="hero-inner">
                <span class="service-icon" aria-hidden="true">
                    {service.data.icon}
                </span>
                <div>
                    <span class="sec-subtitle">Nuestros Servicios</span>
                    <h1>{service.data.title}</h1>
                    <p class="service-tagline">{service.data.tagline}</p>
                    <p class="service-price">
                        Estimado desde
                        <strong>${service.data.price} USD</strong>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTENIDO PRINCIPAL -->
    <section class="service-content container">
        <div class="prose-wrapper">
            <div class="prose">
                <Content />
            </div>
        </div>
    </section>

    <!-- CTA BANNER -->
    <section class="cta-banner container">
        <div class="cta-banner-box">
            <div class="cta-text-cnt">
                <h2>¿Interesado en este servicio?</h2>
                <p>
                    Contáctanos hoy y recibe una inspección gratuita y un
                    presupuesto detallado en menos de 24 horas.
                </p>
            </div>
            <div class="cta-action-cnt">
                <a
                    href={`${import.meta.env.BASE_URL}contact`}
                    class="btn-white-accent"
                >
                    Solicitar este Servicio →
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO DE PÁGINA */
    .page-hero {
        background-color: #0f172a;
        color: #fff;
        padding: 80px 24px;
    }

    .back-link {
        display: inline-block;
        color: #94a3b8;
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 32px;
        transition: color 0.2s ease;
    }

    .back-link:hover {
        color: #fff;
    }

    .hero-inner {
        display: flex;
        align-items: flex-start;
        gap: 28px;
    }

    .service-icon {
        font-size: 4rem;
        line-height: 1;
        flex-shrink: 0;
        margin-top: 4px;
    }

    .sec-subtitle {
        color: #395ca0;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        display: block;
        margin-bottom: 12px;
    }

    .page-hero h1 {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.15;
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .service-tagline {
        font-size: 1.1rem;
        color: #cbd5e1;
        line-height: 1.6;
        margin-bottom: 12px;
    }

    .service-price {
        font-size: 0.95rem;
        color: #94a3b8;
        margin: 0;
    }

    .service-price strong {
        color: #93c5fd;
        font-size: 1.1rem;
    }

    /* CONTENIDO MARKDOWN */
    .service-content {
        padding: 80px 24px;
    }

    .prose-wrapper {
        max-width: 760px;
    }

    .prose h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 40px 0 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    .prose h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0f172a;
        margin: 28px 0 12px;
    }

    .prose p {
        font-size: 1.05rem;
        color: #475569;
        line-height: 1.8;
        margin-bottom: 18px;
    }

    .prose ul,
    .prose ol {
        padding-left: 24px;
        margin-bottom: 18px;
    }

    .prose li {
        font-size: 1rem;
        color: #475569;
        line-height: 1.7;
        margin-bottom: 6px;
    }

    .prose strong {
        color: #0f172a;
        font-weight: 600;
    }

    /* CTA BANNER */
    .cta-banner {
        padding: 80px 24px;
    }

    .cta-banner-box {
        background-color: #395ca0;
        border-radius: 16px;
        padding: 48px 60px;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 40px;
        box-shadow: 0 20px 45px rgba(57, 92, 160, 0.25);
    }

    .cta-text-cnt {
        max-width: 600px;
    }

    .cta-banner-box h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 12px;
        line-height: 1.2;
    }

    .cta-banner-box p {
        font-size: 1.1rem;
        color: #e2e8f0;
        line-height: 1.5;
        margin: 0;
    }

    .btn-white-accent {
        display: inline-block;
        background-color: #fff;
        color: #395ca0;
        padding: 16px 32px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 1.05rem;
        white-space: nowrap;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        transition: all 0.25s ease;
    }

    .btn-white-accent:hover {
        background-color: #f1f5f9;
        color: #293a8b;
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    }

    /* ---- SOPORTE MODO OSCURO ---- */
    @media (prefers-color-scheme: dark) {
        .sec-subtitle {
            color: #60a5fa;
        }

        .prose h1,
        .prose h2,
        .prose h3,
        .prose strong {
            color: #f1f5f9;
        }

        .prose h2 {
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        .prose p,
        .prose li {
            color: #94a3b8;
        }
    }

    @media (max-width: 1024px) {
        .cta-banner-box {
            flex-direction: column;
            text-align: center;
            padding: 40px;
        }
    }

    @media (max-width: 768px) {
        .page-hero {
            padding: 60px 16px;
        }

        .hero-inner {
            flex-direction: column;
            gap: 16px;
        }

        .page-hero h1 {
            font-size: 2rem;
        }

        .service-content,
        .cta-banner {
            padding: 60px 16px;
        }
    }
</style>
