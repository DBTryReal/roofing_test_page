---
// ①─────────────────────────────────────────────────────────────────────────
// FRONTMATTER — This block runs at BUILD TIME (Node.js), not in the browser.
// Everything written here disappears from the client bundle.
// ─────────────────────────────────────────────────────────────────────────

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
// ↑ Official Astro component. Processes images with Sharp:
//   converts to WebP, infers width/height, auto-generates srcset.

const allProjects = await getCollection("gallery");
const projects = allProjects.sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);
const categories = [...new Set(projects.map((p) => p.data.category))];

// // ② Import each image — Astro must know the files at build time.
// //   Dynamic paths with variables are NOT allowed here (Vite/Rollup limitation).
// //   Each import generates a { src, width, height, format } object consumed by <Image>.

// // ③ Projects array — centralizes all data in one place.
// //   "category" is the value used by the filter buttons (data-filter).

// // ④ Extract unique categories from the array → avoids duplicating text manually.
// //   Set removes duplicates. The spread [...] converts the Set to an Array for .map().
// const categories = [...new Set(projects.map((p) => p.category))];
---

<!--
  ⑤ BaseLayout receives title and description.
  - title appears in the <title> of the <head> → important for SEO (browser tab, Google)
  - description goes in <meta name="description"> → shown in search results
-->
<BaseLayout
  title="Project Gallery"
  description="Gallery of completed roofing projects in North Carolina: repairs, installations, and roof maintenance."
>

   <!-- ⑥ INTRO SECTION
    h1: there should be ONLY ONE h1 per page. It is the main heading for SEO.
    class="container" centers content respecting the global max-width.
  -->
  <section class="page-hero">
    <div class="container">
      <span class="sec-subtitle">Our Projects</span>
      <h1>Project Gallery</h1>
      <p>
        Explore our featured work in roofing repair, installation, and
        maintenance across North Carolina.
      </p>
    </div>
  </section>

  <!-- ⑦ FILTERS
    role="group": semantically groups related buttons (ARIA)
    aria-label: describes the group for screen readers
    data-filter="all": special value that shows all items
    aria-pressed: communicates to screen readers whether the button is active (toggle)
    Counts ({projects.filter...length}) help the user anticipate results
  -->
  <div
    class="gallery-filters container"
    role="group"
    aria-label="Filter projects by category"
  >
    <button class="filter-btn active" data-filter="all" aria-pressed="true">
      All ({projects.length})
    </button>
    {
      categories.map((cat) => (
        <button class="filter-btn" data-filter={cat} aria-pressed="false">
          {cat.charAt(0).toUpperCase() + cat.slice(1)} (
          {projects.filter((p) => p.data.category === cat).length})
        </button>
      ))
    }
  </div>

    <!-- ⑧ IMAGE GRID
    id="gallery-grid": selected by JS to handle the empty state
    role="list" + role="listitem": correct semantics for a list of items
    (CSS grid has no list semantics by default)
  -->
  <div class="gallery-grid container" id="gallery-grid" role="list">
    {
      projects.map((project, index) => (
        <!-- ⑨ <figure> is the correct HTML element for a related image + caption -->
        <figure
          class="gallery-item"
          data-category={project.data.category}
          role="listitem"
        >
          <!--
            ⑩ <button> wraps the image to make it clickable and keyboard-navigable
            (Tab + Enter/Space). Using <div onClick> would be incorrect for accessibility.
            aria-label describes the ACTION ("Expand image of..."), not the image itself.
            The image description is handled by the alt attribute of <Image>.
            data-index stores the position in the array for the lightbox.
          -->
          <button
            class="gallery-trigger"
            aria-label={`View full image: ${project.data.title} in ${project.data.location}`}
            data-index={index}
          >
            <!--
              ⑪ <Image> from astro:assets — differences vs a plain <img>:
              · src accepts the imported OBJECT (not a URL string)
              · Automatically generates <img srcset="..." sizes="..."> for responsive
              · Converts to WebP at build time (Sharp)
              · width + height → the browser reserves space before loading
                → prevents Cumulative Layout Shift (CLS), a Core Web Vitals metric
              · loading="lazy" → the browser loads the image only when it enters
                the viewport. Reduces initial load time.
              · decoding="async" → the browser decodes the image in the background
                without blocking the main thread (non-blocking rendering)
            -->
            <Image
              src={project.data.image}
              alt={project.data.alt}
              width={800}
              height={600}
              loading="lazy"
              decoding="async"
              class="gallery-img"
            />

            <!--
              ⑫ Hover OVERLAY — appears over the image on cursor hover.
              aria-hidden="true": the overlay text is decorative/redundant
              (figcaption already has the same text) → screen readers ignore it.
              The overlay uses position:absolute + opacity transition (see CSS).
            -->
            <div class="gallery-overlay" aria-hidden="true">
              <strong>{project.data.title}</strong>
              <span>{project.data.location}</span>
            </div>
          </button>

          <!--
            ⑬ <figcaption> is the visible text below the image.
            Semantically describes the content of <figure>.
            This text is read by screen readers (the overlay with aria-hidden is not).
            It is also indexed by Google as descriptive text for the image.
          -->
          <figcaption>
            <strong>{project.data.title}</strong>
            <span>{project.data.location}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>

  <!--
    ⑭ EMPTY STATE MESSAGE
    Shown when a filter has no results.
    aria-live="polite": screen readers announce the text change
    when it appears, without interrupting what they are currently reading.
    hidden: native HTML attribute, more semantic than display:none via class.
  -->
  <p
    class="gallery-empty container"
    id="gallery-empty"
    aria-live="polite"
    hidden
  >
    No projects in this category yet.
  </p>

    <!--
    ⑮ LIGHTBOX with <dialog> — native HTML element for modals.
    Advantages over a hand-rolled <div> modal:
    · ESC to close: works natively without extra JS
    · Focus trap: keyboard focus stays trapped inside the dialog
    · ::backdrop pseudo-element for the dark background
    · showModal() / close() are native methods
    aria-modal="true": reinforces to screen readers that content
    outside the dialog is inert while it's open.
    aria-label: accessible name of the dialog.
  -->
  <dialog class="lightbox" id="lightbox" aria-modal="true" aria-label="Image viewer">
    <!--
      ⑯ Close button — minimum 44x44px recommended by WCAG for touch targets.
      aria-label describes the action (the "✕" symbol has no meaning on its own).
    -->
    <button class="lightbox-close" id="lightbox-close" aria-label="Close image viewer">
      ✕
    </button>

    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous image">
      ‹
    </button>

    <figure class="lightbox-figure">
      <!--
        ⑰ The lightbox image uses a plain <img> (not Astro's <Image>)
        because its src is populated dynamically by JS at runtime.
        astro:assets only processes images known at build time.
        Empty src="" + width/height reserve space to avoid reflow.
      -->
      <img
        id="lightbox-img"
        src=""
        alt=""
        width="1200"
        height="900"
        decoding="async"
      />
      <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
    </figure>

    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next image">
      ›
    </button>
  </dialog>

  <!-- CTA BANNER -->
  <section class="cta-banner container">
    <div class="cta-banner-box">
      <div class="cta-text-cnt">
        <h2>Ready to start your next project?</h2>
        <p>
          Contact us today and receive a free inspection plus a
          detailed quote in less than 24 hours.
        </p>
      </div>
      <div class="cta-action-cnt">
        <a href={`${import.meta.env.BASE_URL}contact`} class="btn-white-accent">
          Get a Free Quote →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── PAGE HERO ─────────────────────────────────────────────── */
  .page-hero {
    background-color: #0f172a;
    color: #fff;
    padding: 80px 24px;
  }
  .sec-subtitle {
    color: #395ca0;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 12px;
  }
  .page-hero h1 {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }
  .page-hero p {
    font-size: 1.15rem;
    color: #cbd5e1;
    line-height: 1.6;
    max-width: 600px;
  }

  /* ── FILTERS ─────────────────────────────────────────────────────── */
  .gallery-filters {
    display: flex;
    flex-wrap: wrap; /* Wrap to next line if they don't fit */
    gap: 8px;
    justify-content: center;
    padding: 0 0 32px;
    margin-top: 80px;
  }
  .filter-btn {
    background: #f0f4f8;
    border: 2px solid transparent;
    border-radius: 999px; /* Perfect pill shape */
    padding: 8px 20px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #555;
    font-family: inherit;  /* Hering Poppins of body */
  }
  .filter-btn:hover {
    border-color: #395ca0;
    color: #395ca0;
  }
  /* Active state — class + aria-pressed for double coverage */
  .filter-btn.active,
  .filter-btn[aria-pressed="true"] {
    background: #395ca0;
    color: #fff;
    border-color: #395ca0;
  }
   /* focus-visible: focus ring ONLY with keyboard, not mouse (better UX) */
  .filter-btn:focus-visible {
    outline: 3px solid #395ca0;
    outline-offset: 2px;
  }

  /* ── GRID ────────────────────────────────────────────────────────── */

  /* ══ Uniform grid (clean, professional) ════════════════
    auto-fill: creates ALL columns that fit the available width
    minmax(280px, 1fr): each column is min 280px and max 1fr
    Effect: large screen → 3-4 cols, tablet → 2, mobile → 1
    Fully responsive with no media queries.
  ══════════════════════════════════════════════════════════════════ */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding-bottom: 64px;    
    /* Prevents items with different captions from stretching */
    align-items: start; 
  }

  /* ── ITEM ────────────────────────────────────────────────────────── */
  .gallery-item {
    margin: 0;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    background: #fff;
  }
  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.14);
  }
  /* [hidden] is the native attribute used by JS to hide filtered items */
  .gallery-item[hidden] {
    display: none; /* necessary to override the display:block of the element */
  }

  /* ── TRIGGER (button wrapping the image) ──────────────────────── */
  .gallery-trigger {
    position: relative;    /* Necessary for the absolute overlay to be positioned here */
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    display: block;
    overflow: hidden;      /* The zoom of the image does not go outside the container */
  }
  .gallery-trigger:focus-visible {
    outline: 3px solid #395ca0;
    outline-offset: 0;
  }

  /* ── IMAGE ──────────────────────────────────────────────────────── */
  .gallery-img {
    width: 100%;
    height: 220px;
    object-fit: cover; /* Crops to fill the space without distortion */
    display: block;
    transition: transform 0.35s ease;
  }
  .gallery-trigger:hover .gallery-img,
  .gallery-trigger:focus-visible .gallery-img {
    transform: scale(1.06);  /* Subtle zoom — attractive and communicates interactivity */
  }

  /* ── OVERLAY ─────────────────────────────────────────────────────── */
  .gallery-overlay {
    position: absolute;
    inset: 0; /* Equivalent to top:0; right:0; bottom:0; left:0; */
    background: linear-gradient(
      to top,
      rgba(41, 58, 139, 0.88) 0%, /* Brand color — dark blue */
      rgba(57, 92, 160, 0.3) 60%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Text at the bottom */
    padding: 16px;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .gallery-trigger:hover .gallery-overlay,
  .gallery-trigger:focus-visible .gallery-overlay {
    opacity: 1;
  }
  .gallery-overlay strong {
    font-size: 0.95rem;
    font-weight: 600;
    display: block;
  }
  .gallery-overlay span {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  /* ── FIGCAPTION ──────────────────────────────────────────────────── */
  .gallery-item figcaption {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .gallery-item figcaption strong {
    font-size: 0.9rem;
    color: #1a1a1a;
  }
  .gallery-item figcaption span {
    font-size: 0.8rem;
    color: #777;
  }

  /* ── EMPTY STATE ────────────────────────────────────────────────── */
  .gallery-empty {
    text-align: center;
    color: #888;
    padding: 48px 24px;
    font-size: 1rem;
  }

  /* ── LIGHTBOX (<dialog>) ─────────────────────────────────────────── */
  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100dvh; /* dvh: dynamic viewport height, correct on mobile */
    width: 100vw;
    height: 100dvh;
    position: fixed;  /* Required to cover the full screen */
  }
  /*
    ::backdrop — native pseudo-element of <dialog>.
    This is the dark background behind the modal.
    Only exists when the dialog is opened with showModal().
  */
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(4px); /* Blurs content behind */
  }
  .lightbox-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    margin: 0;
    padding: 64px 80px;
    box-sizing: border-box;
  }
  #lightbox-img {
    max-height: calc(100dvh - 140px);  /* Space for caption and buttons */
    max-width: 100%;
    object-fit: contain; /* Displays the full image without cropping */
    border-radius: 6px;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.5);
  }
  .lightbox-caption {
    color: #ddd;
    font-size: 0.9rem;
    margin-top: 14px;
    text-align: center;
  }
  /* Lightbox buttons — minimum 44x44px (WCAG 2.5.5) */
  .lightbox-close {
    position: fixed;
    top: 16px;
    right: 20px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font-size: 1.4rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    font-family: inherit;
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }
  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font-size: 2.2rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
    font-family: inherit;
  }
  .lightbox-prev { left: 16px; }
  .lightbox-next { right: 16px; }
  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.28); }
  .lightbox-nav:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }
  .lightbox-close:focus-visible,
  .lightbox-nav:focus-visible {
    outline: 3px solid #fff;
    outline-offset: 2px;
  }

  /* ── CTA BANNER ─────────────────────────────────────────────────── */
  .cta-banner {
    padding: 80px 24px;
  }
  .cta-banner-box {
    background-color: #395ca0;
    border-radius: 16px;
    padding: 48px 60px;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    box-shadow: 0 20px 45px rgba(57, 92, 160, 0.25);
  }
  .cta-text-cnt {
    max-width: 600px;
  }
  .cta-banner-box h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .cta-banner-box p {
    font-size: 1.1rem;
    color: #e2e8f0;
    line-height: 1.5;
    margin: 0;
  }
