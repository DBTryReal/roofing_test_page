// ①─────────────────────────────────────────────────────────────────────────
// FRONTMATTER — Este bloque se ejecuta en BUILD TIME (Node.js), no en el
// navegador. Todo lo que escribas aquí desaparece del bundle del cliente.
// ─────────────────────────────────────────────────────────────────────────

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
// ↑ Componente oficial de Astro. Procesa la imagen con Sharp:
//   convierte a WebP, infiere width/height, genera srcset automático.

const allProjects = await getCollection("gallery");
const projects = allProjects.sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);
const categories = [...new Set(projects.map((p) => p.data.category))];

// // ② Importar cada imagen — Astro necesita conocer los archivos en build time.
// //   NO se pueden usar rutas dinámicas con variables aquí (limitación de Vite/Rollup).
// //   Cada import genera un objeto { src, width, height, format } que <Image> consume.
// import p1 from "../assets/images/gallery/proyecto-1.webp";
// import p2 from "../assets/images/gallery/proyecto-2.webp";
// import p3 from "../assets/images/gallery/proyecto-3.webp";
// import p4 from "../assets/images/gallery/proyecto-4.webp";
// import p5 from "../assets/images/gallery/proyecto-5.webp";
// import p6 from "../assets/images/gallery/proyecto-6.webp";

// // ③ Array de proyectos — centraliza todos los datos en un solo lugar.
// //   "category" es el valor que usarán los botones de filtro (data-filter).
// const projects = [
//   {
//     src: p1,
//     alt: "Techo residencial reparado con tejas nuevas en Charlotte, NC",
//     title: "Reparación residencial",
//     location: "Charlotte, NC",
//     category: "reparacion",
//   },
//   {
//     src: p2,
//     alt: "Instalación de techo nuevo con acabado moderno en Raleigh, NC",
//     title: "Instalación nueva",
//     location: "Raleigh, NC",
//     category: "instalacion",
//   },
//   {
//     src: p3,
//     alt: "Mantenimiento preventivo de techo en Durham, NC",
//     title: "Mantenimiento preventivo",
//     location: "Durham, NC",
//     category: "mantenimiento",
//   },
//   {
//     src: p4,
//     alt: "Reparación de urgencia tras tormenta en Cary, NC",
//     title: "Reparación urgente",
//     location: "Cary, NC",
//     category: "reparacion",
//   },
//   {
//     src: p5,
//     alt: "Instalación de tejas de asfalto en Greensboro, NC",
//     title: "Tejas de asfalto",
//     location: "Greensboro, NC",
//     category: "instalacion",
//   },
//   {
//     src: p6,
//     alt: "Inspección y sellado de goteras en Apex, NC",
//     title: "Reparación de goteras",
//     location: "Apex, NC",
//     category: "mantenimiento",
//   },   
// ];

// // ④ Extraer categorías únicas desde el array → evita duplicar texto manualmente.
// //   Set elimina repetidos. El spread [...] convierte el Set a Array para .map().
// const categories = [...new Set(projects.map((p) => p.category))];
---

<!--
  ⑤ BaseLayout recibe title y description.
  - title aparece en <title> del <head> → importante para SEO (tab del navegador, Google)
  - description va en <meta name="description"> → aparece en los resultados de búsqueda
-->
<BaseLayout
  title="Galería de Proyectos"
  description="Galería de proyectos de roofing completados en Carolina del Norte: reparaciones, instalaciones y mantenimiento de techos."
>

  <!-- ⑥ SECCIÓN INTRO
    h1: debe haber SOLO UN h1 por página. Es el encabezado principal para SEO.
    El actual gallery.astro usa h2 — esto es un error SEO si no hay h1 padre.
    class="container" centra el contenido respetando el max-width global.
  -->  
  <section class="page-hero">
    <div class="container">
      <span class="sec-subtitle">Nuestros Proyectos</span>
      <h1>Galería de Proyectos</h1>
      <p>
        Explora nuestros trabajos destacados en reparación, instalación y
        mantenimiento de techos en Carolina del Norte.
      </p>
    </div>
  </section>

  <!-- ⑦ FILTROS
    role="group": agrupa semánticamente botones relacionados (ARIA)
    aria-label: describe el grupo para lectores de pantalla
    data-filter="all": valor especial que muestra todos los items
    aria-pressed: comunica a screen readers si el botón está activo (toggle)
    Los counts ({projects.filter...length}) ayudan al usuario a anticipar resultados
  -->
  <div
    class="gallery-filters container"
    role="group"
    aria-label="Filtrar proyectos por categoría"
  >
    <button class="filter-btn active" data-filter="all" aria-pressed="true">
      Todos ({projects.length})
    </button>
    {
      categories.map((cat) => (
        <button class="filter-btn" data-filter={cat} aria-pressed="false">
          {cat.charAt(0).toUpperCase() + cat.slice(1)} (
          {projects.filter((p) => p.data.category === cat).length})
        </button>
      ))
    }
  </div>

  <!-- ⑧ GRID DE IMÁGENES
    id="gallery-grid": lo selecciona el JS para manejar el estado vacío
    role="list" + role="listitem": semántica correcta para una lista de ítems
    (CSS grid no tiene semántica de lista por defecto)
  -->
  <div class="gallery-grid container" id="gallery-grid" role="list">
    {
      projects.map((project, index) => (
        <!-- ⑨ <figure> es el elemento HTML correcto para imagen + caption relacionados -->
        <figure
          class="gallery-item"
          data-category={project.data.category}
          role="listitem"
        >
          <!--
            ⑩ <button> envuelve la imagen para hacerla clickeable y navegable
            por teclado (Tab + Enter/Space). Usar <div onClick> sería incorrecto
            para accesibilidad.
            aria-label describe la ACCIÓN ("Ampliar imagen de..."), no la imagen.
            La descripción de la imagen la hace el alt del <Image>.
            data-index almacena la posición en el array para el lightbox.
          -->
          <button
            class="gallery-trigger"
            aria-label={`Ampliar imagen: ${project.data.title} en ${project.data.location}`}
            data-index={index}
          >
            <!--
              ⑪ <Image> de astro:assets — diferencias vs <img> normal:
              · src recibe el OBJETO importado (no un string de URL)
              · Genera automáticamente <img srcset="..." sizes="..."> para responsive
              · Convierte a WebP en build time (Sharp)
              · width + height → el navegador reserva espacio antes de cargar
                → evita Cumulative Layout Shift (CLS), métrica Core Web Vitals
              · loading="lazy" → el navegador carga la imagen solo cuando entra
                en el viewport. Reduce tiempo de carga inicial.
              · decoding="async" → el navegador decodifica la imagen en segundo
                plano sin bloquear el hilo principal (no bloquea la renderización)
            -->
            <Image
              src={project.data.image}
              alt={project.data.alt}
              width={800}
              height={600}
              loading="lazy"
              decoding="async"
              class="gallery-img"
            />

            <!--
              ⑫ OVERLAY de hover — aparece sobre la imagen al pasar el cursor.
              aria-hidden="true": el texto del overlay es decorativo/redundante
              (figcaption ya tiene el mismo texto) → los screen readers lo ignoran.
              El overlay usa position:absolute + opacity transition (ver CSS).
            -->
            <div class="gallery-overlay" aria-hidden="true">
              <strong>{project.data.title}</strong>
              <span>{project.data.location}</span>
            </div>
          </button>

          <!--
            ⑬ <figcaption> es el texto visible bajo la imagen.
            Semánticamente describe el contenido de <figure>.
            El texto aquí es leído por screen readers (el overlay con aria-hidden no).
            También es indexado por Google como texto descriptivo de la imagen.
          -->
          <figcaption>
            <strong>{project.data.title}</strong>
            <span>{project.data.location}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>

  <!--
    ⑭ MENSAJE DE ESTADO VACÍO
    Se muestra cuando un filtro no tiene resultados.
    aria-live="polite": los screen readers anuncian el cambio de texto
    cuando aparece, sin interrumpir lo que están leyendo.
    hidden: atributo nativo HTML, más semántico que display:none con clase.
  -->
  <p
    class="gallery-empty container"
    id="gallery-empty"
    aria-live="polite"
    hidden
  >
    No hay proyectos en esta categoría todavía.
  </p>

  <!--
    ⑮ LIGHTBOX con <dialog> — elemento HTML nativo para modales.
    Ventajas sobre un <div> modal hecho a mano:
    · ESC para cerrar: funciona nativamente sin JS extra
    · Focus trap: el foco del teclado queda atrapado dentro del dialog
    · ::backdrop pseudo-elemento para el fondo oscuro
    · showModal() / close() son métodos nativos
    aria-modal="true": refuerza a los screen readers que el contenido
    fuera del dialog está inerte mientras está abierto.
    aria-label: nombre del dialog para tecnología asistiva.
  -->
  <dialog class="lightbox" id="lightbox" aria-modal="true" aria-label="Visor de imágenes">
    <!--
      ⑯ Botón cerrar — mínimo 44x44px recomendado por WCAG para targets táctiles.
      aria-label describe la acción (el símbolo "✕" no tiene significado por sí solo).
    -->
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar visor de imágenes">
      ✕
    </button>

    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Imagen anterior">
      ‹
    </button>

    <figure class="lightbox-figure">
      <!--
        ⑰ La imagen del lightbox usa <img> normal (no <Image> de Astro)
        porque su src se rellena dinámicamente por JS en runtime.
        astro:assets solo procesa imágenes conocidas en build time.
        src="" vacío + width/height reservan el espacio para evitar reflow.
      -->
      <img
        id="lightbox-img"
        src=""
        alt=""
        width="1200"
        height="900"
        decoding="async"
      />
      <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
    </figure>

    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Imagen siguiente">
      ›
    </button>
  </dialog>

  <!-- CTA BANNER -->
  <section class="cta-banner container">
    <div class="cta-banner-box">
      <div class="cta-text-cnt">
        <h2>¿Listo para tu próximo proyecto?</h2>
        <p>
          Contáctanos hoy y recibe una inspección gratuita y un
          presupuesto detallado en menos de 24 horas.
        </p>
      </div>
      <div class="cta-action-cnt">                
        <a href={`${import.meta.env.BASE_URL}contact`} class="btn-white-accent">
          Solicitar Cotización Gratis →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO DE PÁGINA ─────────────────────────────────────────────── */
  .page-hero {
    background-color: #0f172a;
    color: #fff;
    padding: 80px 24px;
  }
  .sec-subtitle {
    color: #395ca0;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 12px;
  }
  .page-hero h1 {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }
  .page-hero p {
    font-size: 1.15rem;
    color: #cbd5e1;
    line-height: 1.6;
    max-width: 600px;
  }

  /* ── FILTROS ─────────────────────────────────────────────────────── */
  .gallery-filters {
    display: flex;
    flex-wrap: wrap;       /* Si no caben en una línea, pasan a la siguiente */
    gap: 8px;
    justify-content: center;
    padding: 0 0 32px;
    margin-top: 80px;
  }
  .filter-btn {
    background: #f0f4f8;
    border: 2px solid transparent;
    border-radius: 999px;  /* Cápsula perfecta */
    padding: 8px 20px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #555;
    font-family: inherit;  /* Hereda Poppins del body */
  }
  .filter-btn:hover {
    border-color: #395ca0;
    color: #395ca0;
  }
  /* Estado activo — clase + aria-pressed para doble cobertura */
  .filter-btn.active,
  .filter-btn[aria-pressed="true"] {
    background: #395ca0;
    color: #fff;
    border-color: #395ca0;
  }
  /* focus-visible: anillo de foco SOLO con teclado, no con mouse (mejor UX) */
  .filter-btn:focus-visible {
    outline: 3px solid #395ca0;
    outline-offset: 2px;
  }

  /* ── GRID ────────────────────────────────────────────────────────── */

  /* ══ Uniform grid (limpio, profesional) ════════════════
    auto-fill: crea TODAS las columnas que quepan en el ancho disponible
    minmax(280px, 1fr): cada columna tiene mínimo 280px y máximo 1fr
    Efecto: en pantalla grande → 3-4 columnas, en tablet → 2, en móvil → 1
    100% responsive sin media queries.
  ══════════════════════════════════════════════════════════════════ */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding-bottom: 64px;    
    /* Evita que items con caption diferente se estiren */
    align-items: start; 
  }

  /* ── ITEM ────────────────────────────────────────────────────────── */
  .gallery-item {
    margin: 0;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    background: #fff;
  }
  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.14);
  }
  /* [hidden] es el atributo nativo que usa JS para ocultar ítems filtrados */
  .gallery-item[hidden] {
    display: none; /* necesario para sobrescribir el display:block del elemento */
  }

  /* ── TRIGGER (botón que envuelve la imagen) ──────────────────────── */
  .gallery-trigger {
    position: relative;    /* Necesario para que el overlay absolute se posicione aquí */
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    display: block;
    overflow: hidden;      /* El zoom de la imagen no se sale del contenedor */
  }
  .gallery-trigger:focus-visible {
    outline: 3px solid #395ca0;
    outline-offset: 0;
  }

  /* ── IMAGEN ──────────────────────────────────────────────────────── */
  .gallery-img {
    width: 100%;
    height: 220px;
    object-fit: cover;        /* Recorta para llenar el espacio sin distorsión */
    display: block;
    transition: transform 0.35s ease;
  }
  .gallery-trigger:hover .gallery-img,
  .gallery-trigger:focus-visible .gallery-img {
    transform: scale(1.06);   /* Zoom sutil — atractivo y comunica interactividad */
  }

  /* ── OVERLAY ─────────────────────────────────────────────────────── */
  .gallery-overlay {
    position: absolute;
    inset: 0;               /* Equivale a top:0; right:0; bottom:0; left:0; */
    background: linear-gradient(
      to top,
      rgba(41, 58, 139, 0.88) 0%,   /* Color del tema — azul oscuro */
      rgba(57, 92, 160, 0.3) 60%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;   /* Texto en la parte inferior */
    padding: 16px;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .gallery-trigger:hover .gallery-overlay,
  .gallery-trigger:focus-visible .gallery-overlay {
    opacity: 1;
  }
  .gallery-overlay strong {
    font-size: 0.95rem;
    font-weight: 600;
    display: block;
  }
  .gallery-overlay span {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  /* ── FIGCAPTION ──────────────────────────────────────────────────── */
  .gallery-item figcaption {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .gallery-item figcaption strong {
    font-size: 0.9rem;
    color: #1a1a1a;
  }
  .gallery-item figcaption span {
    font-size: 0.8rem;
    color: #777;
  }

  /* ── ESTADO VACÍO ────────────────────────────────────────────────── */
  .gallery-empty {
    text-align: center;
    color: #888;
    padding: 48px 24px;
    font-size: 1rem;
  }

  /* ── LIGHTBOX (<dialog>) ─────────────────────────────────────────── */
  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100dvh;   /* dvh: dynamic viewport height, correcto en móvil */
    width: 100vw;
    height: 100dvh;
    position: fixed;      /* Necesario para que cubra toda la pantalla */
  }
  /*
    ::backdrop — pseudo-elemento nativo del <dialog>.
    Es el fondo oscuro detrás del modal.
    Solo existe cuando el dialog está abierto con showModal().
  */
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(4px);   /* Desenfoca el contenido detrás */
  }
  .lightbox-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    margin: 0;
    padding: 64px 80px;
    box-sizing: border-box;
  }
  #lightbox-img {
    max-height: calc(100dvh - 140px);  /* Espacio para caption y botones */
    max-width: 100%;
    object-fit: contain;   /* Muestra la imagen completa sin recortar */
    border-radius: 6px;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.5);
  }
  .lightbox-caption {
    color: #ddd;
    font-size: 0.9rem;
    margin-top: 14px;
    text-align: center;
  }
  /* Botones del lightbox — mínimo 44x44px (WCAG 2.5.5) */
  .lightbox-close {
    position: fixed;
    top: 16px;
    right: 20px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font-size: 1.4rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    font-family: inherit;
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }
  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font-size: 2.2rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
    font-family: inherit;
  }
  .lightbox-prev { left: 16px; }
  .lightbox-next { right: 16px; }
  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.28); }
  .lightbox-nav:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }
  .lightbox-close:focus-visible,
  .lightbox-nav:focus-visible {
    outline: 3px solid #fff;
    outline-offset: 2px;
  }

  /* ── CTA BANNER ─────────────────────────────────────────────────── */
  .cta-banner {
    padding: 80px 24px;
  }
  .cta-banner-box {
    background-color: #395ca0;
    border-radius: 16px;
    padding: 48px 60px;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    box-shadow: 0 20px 45px rgba(57, 92, 160, 0.25);
  }
  .cta-text-cnt {
    max-width: 600px;
  }
  .cta-banner-box h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .cta-banner-box p {
    font-size: 1.1rem;
    color: #e2e8f0;
    line-height: 1.5;
    margin: 0;
  }
  /* .btn-white-accent {
    display: inline-block;
    background-color: #fff;
    color: #395ca0;
    background-color: #4a7fd4;
    color: #f1f5f9;
    padding: 16px 32px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.05rem;
    white-space: nowrap;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    transition: all 0.25s ease;
  }
  .btn-white-accent:hover {
    background-color: #f1f5f9;
    color: #293a8b;
    background-color: #3b6cbf;
    color: #e3effb;
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
  } */

  /* ── RESPONSIVE ──────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }
    .page-hero { padding: 60px 16px; }
    .page-hero h1 { font-size: 2rem; }
    .cta-banner { padding: 60px 16px; }
    .cta-banner-box {
      flex-direction: column;
      text-align: center;
      padding: 40px;
    }
    .lightbox-figure { padding: 52px 12px 32px; }
    /* En móvil se navega con swipe (ver JS), los botones sobran */
    .lightbox-nav { display: none; }
  }
</style>

<!--
  ⑱ <script> en Astro — se ejecuta en el navegador (client-side).
  Astro lo procesa con Vite: bundling, minificación, tree-shaking.
  Se ejecuta una sola vez cuando la página carga.
  TypeScript es soportado directamente (Astro lo transpila).
-->
<script>
  // ══ FILTROS ══════════════════════════════════════════════════════
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".gallery-item");
  const emptyMsg = document.getElementById(
    "gallery-empty"
  ) as HTMLParagraphElement;

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      // dataset.filter lee el atributo data-filter del botón

      // 1. Resetear todos los botones
      filterBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      // 2. Activar el botón clickeado
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");

      // 3. Mostrar/ocultar items según categoría
      let visibleCount = 0;
      items.forEach((item) => {
        const isMatch =
          filter === "all" || item.dataset.category === filter;
        item.hidden = !isMatch;
        // item.hidden es el atributo [hidden] nativo de HTML5
        if (isMatch) visibleCount++;
      });

      // 4. Mostrar mensaje si no hay resultados visibles
      emptyMsg.hidden = visibleCount > 0;
    });
  });

  // ══ LIGHTBOX ════════════════════════════════════════════════════
  const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lbCaption = document.getElementById(
    "lightbox-caption"
  ) as HTMLElement;
  const lbClose = document.getElementById("lightbox-close")!;
  const lbPrev = document.getElementById("lightbox-prev") as HTMLButtonElement;
  const lbNext = document.getElementById("lightbox-next") as HTMLButtonElement;

  let currentIndex = 0;

  // Obtener SOLO los triggers visibles (afecta después de filtrar)
  function getVisibleTriggers(): HTMLButtonElement[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>(".gallery-trigger")
    ).filter(
      (t) => !(t.closest(".gallery-item") as HTMLElement)?.hidden
    );
  }

  function openLightbox(index: number) {
    const visible = getVisibleTriggers();
    if (index < 0 || index >= visible.length) return;
    currentIndex = index;

    const trigger = visible[index];
    const img = trigger.querySelector("img")!;
    // Leer el src que Astro:assets generó (ya es WebP optimizado)
    const captionEl = trigger
      .closest(".gallery-item")!
      .querySelector("figcaption")!;

    lbImg.src = img.src;
    lbImg.alt = img.alt;
    // textContent.trim() elimina espacios/saltos de línea del HTML
    lbCaption.textContent = captionEl.textContent?.trim() ?? "";

    // Deshabilitar botones en los extremos del array
    lbPrev.disabled = index === 0;
    lbNext.disabled = index === visible.length - 1;

    lightbox.showModal();
    // showModal() hace dos cosas:
    // 1. Muestra el dialog encima de todo
    // 2. Activa el ::backdrop
    // 3. Atrapa el foco dentro del dialog (focus trap nativo)
  }

  // Abrir lightbox al clickear cualquier trigger
  document.querySelectorAll<HTMLButtonElement>(".gallery-trigger").forEach(
    (trigger, _) => {
      trigger.addEventListener("click", () => {
        const visible = getVisibleTriggers();
        const visibleIndex = visible.indexOf(trigger);
        if (visibleIndex !== -1) openLightbox(visibleIndex);
      });
    }
  );

  lbClose.addEventListener("click", () => lightbox.close());

  lbPrev.addEventListener("click", () => {
    if (currentIndex > 0) openLightbox(currentIndex - 1);
  });
  lbNext.addEventListener("click", () => {
    const visible = getVisibleTriggers();
    if (currentIndex < visible.length - 1) openLightbox(currentIndex + 1);
  });

  // Navegación con teclado dentro del lightbox
  // ESC ya está manejado NATIVAMENTE por <dialog> — no hace falta código
  lightbox.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft" && !lbPrev.disabled) lbPrev.click();
    if (e.key === "ArrowRight" && !lbNext.disabled) lbNext.click();
  });

  // Cerrar al hacer click en el backdrop (área fuera del contenido)
  // e.target === lightbox cuando se hace click en el backdrop
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) lightbox.close();
  });

  // Swipe para móvil (táctil)
  let touchStartX = 0;
  lightbox.addEventListener(
    "touchstart",
    (e) => {
      touchStartX = e.touches[0].clientX;
    },
    { passive: true } // passive:true → no bloquea el scroll, mejor performance
  );
  lightbox.addEventListener(
    "touchend",
    (e) => {
      const delta = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(delta) > 50) {
        // Umbral de 50px para distinguir swipe de tap
        if (delta < 0) lbNext.click(); // swipe izquierda → siguiente
        else lbPrev.click();           // swipe derecha → anterior
      }
    },
    { passive: true }
  );
</script>